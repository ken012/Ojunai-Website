---
/**
 * One mini-section on a sub-feature page: copy on one side, screenshot on the other.
 * Alternates left/right by default if you set `reverse`.
 */
export interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  bullets?: string[];
  screenshot?: { src: string; alt: string };
  reverse?: boolean;
  background?: 'light' | 'alt';
}

const {
  eyebrow,
  title,
  body,
  bullets = [],
  screenshot,
  reverse = false,
  background = 'light',
} = Astro.props;
---

<section class={`subfeat-section subfeat-section-${background} ${reverse ? 'subfeat-section-reverse' : ''}`}>
  <div class="container subfeat-section-grid">
    <div class="subfeat-section-copy">
      {eyebrow && <div class="subfeat-section-eyebrow">{eyebrow}</div>}
      <h2>{title}</h2>
      <p>{body}</p>
      {bullets.length > 0 && (
        <ul class="subfeat-section-bullets">
          {bullets.map((b) => <li>{b}</li>)}
        </ul>
      )}
    </div>
    {screenshot && (
      <figure class="subfeat-section-shot">
        <img src={screenshot.src} alt={screenshot.alt} loading="lazy" />
      </figure>
    )}
  </div>
</section>

<style>
  .subfeat-section { padding: 80px 0; }
  .subfeat-section-alt { background: var(--bg-alt); }
  .subfeat-section + .subfeat-section { border-top: 1px solid var(--border); }
  .subfeat-section-alt + .subfeat-section,
  .subfeat-section + .subfeat-section-alt { border-top: none; }

  .subfeat-section-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: center;
  }
  .subfeat-section-reverse .subfeat-section-grid {
    grid-template-columns: 1.2fr 1fr;
    direction: rtl;
  }
  .subfeat-section-reverse .subfeat-section-copy,
  .subfeat-section-reverse .subfeat-section-shot {
    direction: ltr;
  }

  @media (max-width: 880px) {
    .subfeat-section-grid,
    .subfeat-section-reverse .subfeat-section-grid {
      grid-template-columns: 1fr;
      gap: 32px;
      direction: ltr;
    }
  }

  .subfeat-section-eyebrow {
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .subfeat-section-copy h2 {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.15;
    margin-bottom: 16px;
    color: var(--text);
  }
  .subfeat-section-copy p {
    color: var(--text-2);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .subfeat-section-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .subfeat-section-bullets li {
    color: var(--text);
    font-size: 0.98rem;
    line-height: 1.55;
    padding: 8px 0 8px 28px;
    position: relative;
  }
  .subfeat-section-bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 14px;
    width: 16px;
    height: 16px;
    background: var(--brand-light);
    border-radius: 50%;
  }
  .subfeat-section-bullets li::after {
    content: '✓';
    position: absolute;
    left: 4px;
    top: 8px;
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .subfeat-section-shot {
    margin: 0;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    border: 1px solid var(--border);
    background: white;
  }
  .subfeat-section-shot img {
    width: 100%;
    display: block;
  }
</style>
