---
/**
 * Homepage feature teaser: 4 cards. Full grid lives at /features.
 * Each card represents a category, not a single feature.
 */
const groups = [
  {
    title: 'Inventory & Stock',
    body: 'Live product catalog, low-stock alerts, automatic deduction on every sale. Bulk import via CSV.',
    example: '50+ products tracked in seconds',
    iconPath: 'M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0',
  },
  {
    title: 'Sales, Credit & Collections',
    body: 'Record every sale — cash or credit. Track customer balances, supplier debts, and aging in one ledger.',
    example: 'Cash, credit, partial payments — handled',
    iconPath: 'M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  {
    title: 'Reports & Insights',
    body: 'Daily and weekly summaries, cash-flow forecasts, top products, sales velocity. PDF export anytime.',
    example: 'Auto-generated every evening',
    iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
  },
  {
    title: 'WhatsApp AI + Voice AI',
    body: 'The WhatsApp AI Assistant is built into every paid plan — log sales by chat. Voice AI is an optional add-on that answers customer calls 24/7.',
    example: 'Both flow into the same dashboard.',
    iconPath:
      'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.5 12 19.79 19.79 0 011.43 3.4 2 2 0 013.42 1.22h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 9a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z',
    badge: 'AI Channels',
  },
];
---

<section class="section features" id="features">
  <div class="container">
    <div class="section-header">
      <div class="section-label">What Ojunai Does</div>
      <h2>Four ways Ojunai runs your day</h2>
      <p>The essentials below. Sixteen features in total — see them all on the features page.</p>
    </div>
    <div class="features-grid four-up">
      {groups.map((g) => (
        <div class="feature-card">
          {g.badge && <span class="feat-badge">{g.badge}</span>}
          <div class="feat-icon">
            <svg width="26" height="26" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d={g.iconPath} />
            </svg>
          </div>
          <h3>{g.title}</h3>
          <p>{g.body}</p>
          <div class="feat-example">{g.example}</div>
        </div>
      ))}
    </div>
    <a href="#whatsapp-business-os" class="features-wabos-callout">
      <div class="features-wabos-meta">
        <span class="features-wabos-pill">Premium · WhatsApp Business OS</span>
        <h3>Skip the dashboard entirely.</h3>
        <p>
          Run sales, inventory, debts, payments, and PDF receipts through a single WhatsApp
          conversation. The full operational layer of Ojunai, delivered by chat.
        </p>
      </div>
      <div class="features-wabos-cta-col">
        <span class="features-wabos-link">See it →</span>
      </div>
    </a>

    <p class="section-cta">
      <a href="/features">See all 16 features →</a>
    </p>
  </div>
</section>

<style>
  .features-grid.four-up {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 960px) {
    .features-grid.four-up { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .features-grid.four-up { grid-template-columns: 1fr; }
  }
  .feat-badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background: var(--brand);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 4px 10px;
    border-radius: 100px;
    text-transform: uppercase;
  }
  .feature-card { position: relative; }
  .features-wabos-callout {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 28px;
    align-items: center;
    margin-top: 32px;
    padding: 24px 32px;
    background: radial-gradient(120% 200% at 0% 0%, #064E3B 0%, #052E2A 60%, #022014 100%);
    border-radius: 18px;
    text-decoration: none;
    color: white;
    border: 1px solid rgba(37, 211, 102, 0.22);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    box-shadow: 0 14px 40px rgba(15, 80, 50, 0.18);
  }
  .features-wabos-callout:hover {
    transform: translateY(-2px);
    box-shadow: 0 22px 50px rgba(15, 80, 50, 0.3);
    border-color: rgba(37, 211, 102, 0.5);
  }
  @media (max-width: 700px) {
    .features-wabos-callout { grid-template-columns: 1fr; padding: 22px 22px; gap: 14px; }
  }
  .features-wabos-pill {
    display: inline-block;
    background: rgba(37, 211, 102, 0.18);
    color: #6EE7B7;
    border: 1px solid rgba(37, 211, 102, 0.4);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .features-wabos-callout h3 {
    color: white;
    font-size: 1.25rem;
    margin: 0 0 6px;
    line-height: 1.2;
  }
  .features-wabos-callout p {
    color: #CBD5E1;
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0;
  }
  .features-wabos-cta-col {
    text-align: right;
  }
  @media (max-width: 700px) {
    .features-wabos-cta-col { text-align: left; }
  }
  .features-wabos-link {
    display: inline-block;
    background: linear-gradient(135deg, #25D366, #128C7E);
    color: white;
    padding: 11px 22px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.92rem;
    box-shadow: 0 6px 16px rgba(37, 211, 102, 0.4);
    transition: transform 0.2s;
  }
  .features-wabos-callout:hover .features-wabos-link { transform: translateX(4px); }

  .section-cta {
    text-align: center;
    margin-top: 32px;
  }
  .section-cta a {
    color: var(--brand);
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    transition: transform 0.2s;
    display: inline-block;
  }
  .section-cta a:hover { transform: translateX(4px); }
</style>
