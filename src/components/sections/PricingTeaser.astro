---
/**
 * Homepage pricing teaser. Four-card grid for Lite / Operator / Professional /
 * Scale, plus a flat Starter (Free) card below and a link out to /pricing for
 * the full comparison and add-ons.
 *
 * Currency toggle mirrors /pricing — shares the `ojunai-currency` localStorage
 * key so a selection on either page persists across both.
 */

const priceMatrix = {
  lite:         { USD:'$12.99', NGN:'₦18,999',  GHS:'₵149',   KES:'KSh 1,699',  ZAR:'R229',   UGX:'USh 48,999',  GBP:'£9.99' },
  operator:     { USD:'$29',    NGN:'₦42,000',  GHS:'₵349',   KES:'KSh 3,800',  ZAR:'R529',   UGX:'USh 109,000', GBP:'£22.99' },
  professional: { USD:'$79',    NGN:'₦115,000', GHS:'₵949',   KES:'KSh 10,500', ZAR:'R1,449', UGX:'USh 295,000', GBP:'£62.99' },
  scale:        { USD:'$199',   NGN:'₦289,000', GHS:'₵2,399', KES:'KSh 26,500', ZAR:'R3,649', UGX:'USh 745,000', GBP:'£159' },
};

const currencies = ['USD', 'NGN', 'GHS', 'KES', 'ZAR', 'UGX', 'GBP'];

const starterFlat = {
  label: 'Starter',
  priceText: 'Free',
  sub: 'For individuals just getting started',
  features: ['Inventory tracking', 'Sales logging', 'Expense tracking', 'Basic reports', '1 user'],
  cta: { label: 'Start Free', href: 'https://app.ojunai.com/register' },
};

const plans = [
  {
    label: 'Lite',
    priceKey: 'lite',
    priceText: priceMatrix.lite.USD,
    period: '/month',
    sub: 'For solo operators who want WhatsApp built in',
    features: [
      'Everything in Starter',
      'Debt & loan tracking',
      'Customer records',
      'WhatsApp Assistant: 10 actions / week',
      '1 user',
      'Receipt generation',
    ],
    cta: { label: 'Get Started', href: 'https://app.ojunai.com/register?plan=lite', external: true },
    featured: false,
  },
  {
    label: 'Operator',
    priceKey: 'operator',
    priceText: priceMatrix.operator.USD,
    period: '/month',
    sub: 'For small businesses running daily operations',
    features: [
      'Everything in Lite',
      'Manual payment tracking',
      'Basic insights',
      'WhatsApp Assistant: 35 actions / week',
      '1 user · Email receipts',
    ],
    cta: { label: 'Get Started', href: 'https://app.ojunai.com/register?plan=operator', external: true },
    featured: false,
  },
  {
    label: 'Professional',
    priceKey: 'professional',
    priceText: priceMatrix.professional.USD,
    period: '/month',
    sub: 'For businesses that want clarity and control',
    features: [
      'Everything in Operator',
      'Advanced analytics & profit tracking',
      'WhatsApp Assistant: 95 actions / week',
      '3 users',
      'WhatsApp + PDF receipts',
    ],
    cta: { label: 'Get Started', href: 'https://app.ojunai.com/register?plan=professional', external: true },
    featured: true,
    badge: 'Most Popular',
  },
  {
    label: 'Scale',
    priceKey: 'scale',
    priceText: priceMatrix.scale.USD,
    period: '/month',
    sub: 'For teams and growing operations',
    features: [
      'Everything in Professional',
      'Multi-user + multi-location',
      'WhatsApp Assistant: 250 actions / week',
      '6 users · Priority support',
      'Branded receipts + audit logs',
    ],
    cta: { label: 'Get Started', href: 'https://app.ojunai.com/register?plan=scale', external: true },
    featured: false,
  },
];
---

<section class="section pricing-teaser" id="pricing-teaser">
  <div class="container">
    <div class="section-header">
      <div class="section-label">Simple Plans</div>
      <h2>Pricing that scales with your business</h2>
      <p>Start free. Upgrade as you grow. WhatsApp Assistant + add-ons priced à la carte.</p>
    </div>

    <div class="pricing-teaser-switcher" role="tablist" aria-label="Display currency">
      <span class="pricing-teaser-switcher-label">Show prices in</span>
      <div class="pricing-teaser-switcher-pills">
        {currencies.map((c) => (
          <button
            type="button"
            class={`pricing-teaser-pill ${c === 'USD' ? 'pricing-teaser-pill-active' : ''}`}
            data-ccy={c}
            role="tab"
            aria-selected={c === 'USD' ? 'true' : 'false'}
          >
            {c}
          </button>
        ))}
      </div>
    </div>

    <div class="pricing-teaser-grid">
      {plans.map((p) => (
        <div class={`price-card ${p.featured ? 'price-card-featured' : ''}`}>
          {p.badge && <div class="price-badge">{p.badge}</div>}
          <div class="price-label">{p.label}</div>
          <div class="price-amount">
            {p.priceKey
              ? <span data-price-id={p.priceKey}>{p.priceText}</span>
              : p.priceText}
            <span>{p.period}</span>
          </div>
          <div class="price-sub">{p.sub}</div>
          <ul class="price-features">
            {p.features.map((f) => (
              <li>
                <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={p.cta.href}
            target={p.cta.external ? '_blank' : undefined}
            rel={p.cta.external ? 'noopener' : undefined}
            class={`price-btn ${p.featured ? 'price-btn-primary' : 'price-btn-outline'}`}
          >
            {p.cta.label}
          </a>
        </div>
      ))}
    </div>

    <div class="teaser-starter-flat">
      <div class="teaser-starter-flat-meta">
        <div class="teaser-starter-flat-pill">Starter</div>
        <h3>{starterFlat.sub}</h3>
        <ul class="teaser-starter-flat-features">
          {starterFlat.features.map((f) => <li>{f}</li>)}
        </ul>
      </div>
      <div class="teaser-starter-flat-cta-col">
        <div class="teaser-starter-flat-price">{starterFlat.priceText}</div>
        <a href={starterFlat.cta.href} target="_blank" rel="noopener" class="teaser-starter-flat-cta">
          {starterFlat.cta.label}
        </a>
        <p class="teaser-starter-flat-meta">No credit card required</p>
      </div>
    </div>

    <p class="pricing-teaser-cta">
      <a href="/pricing">See all plans + add-ons →</a>
    </p>
  </div>

  <script type="application/json" id="ojunai-teaser-price-matrix" set:html={JSON.stringify(priceMatrix)} />

  <script is:inline>
    (function () {
      const SUPPORTED = ['USD','NGN','GHS','KES','ZAR','UGX','GBP'];
      const TZ_TO_CCY = {
        'Africa/Lagos':'NGN','Africa/Abuja':'NGN','Africa/Port_Harcourt':'NGN','Africa/Kano':'NGN',
        'Africa/Accra':'GHS',
        'Africa/Nairobi':'KES','Africa/Mombasa':'KES',
        'Africa/Johannesburg':'ZAR','Africa/Cape_Town':'ZAR','Africa/Durban':'ZAR',
        'Africa/Kampala':'UGX',
        'Europe/London':'GBP','Europe/Belfast':'GBP','Europe/Jersey':'GBP','Europe/Guernsey':'GBP','Europe/Isle_of_Man':'GBP'
      };
      const REGION_TO_CCY = { NG:'NGN', GH:'GHS', KE:'KES', ZA:'ZAR', UG:'UGX', GB:'GBP', IM:'GBP', JE:'GBP', GG:'GBP' };

      function detect() {
        try {
          const stored = localStorage.getItem('ojunai-currency');
          if (stored && SUPPORTED.indexOf(stored) >= 0) return stored;
        } catch (e) {}
        try {
          const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
          if (TZ_TO_CCY[tz]) return TZ_TO_CCY[tz];
        } catch (e) {}
        try {
          const lang = navigator.language || 'en-US';
          const region = (lang.split('-')[1] || '').toUpperCase();
          if (REGION_TO_CCY[region]) return REGION_TO_CCY[region];
        } catch (e) {}
        return 'USD';
      }

      let matrix = {};
      try {
        const node = document.getElementById('ojunai-teaser-price-matrix');
        matrix = node ? JSON.parse(node.textContent) : {};
      } catch (e) { matrix = {}; }

      const root = document.getElementById('pricing-teaser');
      if (!root) return;

      function apply(ccy) {
        if (SUPPORTED.indexOf(ccy) < 0) ccy = 'USD';
        root.querySelectorAll('[data-price-id]').forEach(function (el) {
          const key = el.getAttribute('data-price-id');
          if (matrix[key] && matrix[key][ccy]) el.textContent = matrix[key][ccy];
        });
        root.querySelectorAll('.pricing-teaser-pill').forEach(function (b) {
          const active = b.getAttribute('data-ccy') === ccy;
          b.classList.toggle('pricing-teaser-pill-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        try { localStorage.setItem('ojunai-currency', ccy); } catch (e) {}
      }

      function init() {
        apply(detect());
        root.querySelectorAll('.pricing-teaser-pill').forEach(function (b) {
          b.addEventListener('click', function () { apply(b.getAttribute('data-ccy')); });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</section>

<style>
  .pricing-teaser-switcher {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
    margin: 0 0 32px;
  }
  .pricing-teaser-switcher-label {
    font-size: 0.85rem;
    color: var(--text-2);
    font-weight: 500;
  }
  .pricing-teaser-switcher-pills {
    display: inline-flex;
    flex-wrap: wrap;
    justify-content: center;
    background: white;
    border: 1px solid var(--border);
    border-radius: 100px;
    padding: 4px;
    box-shadow: 0 2px 6px rgba(15, 23, 42, 0.05);
  }
  .pricing-teaser-pill {
    background: transparent;
    border: 0;
    color: var(--text-2);
    font-weight: 600;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    padding: 7px 12px;
    border-radius: 100px;
    cursor: pointer;
    transition: background 0.15s, color 0.15s;
    font-family: inherit;
  }
  @media (max-width: 480px) {
    .pricing-teaser-pill { padding: 6px 9px; font-size: 0.76rem; }
  }
  .pricing-teaser-pill:hover { color: var(--brand); }
  .pricing-teaser-pill-active {
    background: linear-gradient(135deg, var(--brand-mid), var(--brand));
    color: white;
    box-shadow: 0 4px 10px rgba(79, 70, 229, 0.3);
  }
  .pricing-teaser-pill-active:hover { color: white; }

  .pricing-teaser-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    align-items: stretch;
  }
  @media (max-width: 1100px) {
    .pricing-teaser-grid { grid-template-columns: repeat(2, 1fr); max-width: 720px; margin: 0 auto; }
  }
  @media (max-width: 600px) {
    .pricing-teaser-grid { grid-template-columns: 1fr; max-width: 460px; margin: 0 auto; }
  }
  /* Starter flat card under the 4-card grid */
  .teaser-starter-flat {
    background: linear-gradient(135deg, #FFFFFF 0%, #F8FAFC 100%);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px 32px;
    margin-top: 28px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 28px;
    align-items: center;
    box-shadow: 0 4px 14px rgba(15, 23, 42, 0.04);
  }
  @media (max-width: 800px) {
    .teaser-starter-flat { grid-template-columns: 1fr; padding: 22px 20px; gap: 18px; }
  }
  .teaser-starter-flat-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .teaser-starter-flat h3 {
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 12px;
    font-weight: 600;
  }
  .teaser-starter-flat-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 4px 16px;
  }
  @media (max-width: 700px) {
    .teaser-starter-flat-features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 460px) {
    .teaser-starter-flat-features { grid-template-columns: 1fr; }
  }
  .teaser-starter-flat-features li {
    color: var(--text-2);
    font-size: 0.88rem;
    line-height: 1.5;
    padding-left: 16px;
    position: relative;
  }
  .teaser-starter-flat-features li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--brand);
    font-weight: 700;
  }
  .teaser-starter-flat-cta-col { text-align: center; }
  .teaser-starter-flat-price {
    font-family: var(--font-display);
    font-size: 1.7rem;
    font-weight: 700;
    color: var(--text);
    line-height: 1;
    margin-bottom: 10px;
  }
  .teaser-starter-flat-cta {
    display: inline-block;
    background: white;
    color: var(--brand);
    border: 1.5px solid var(--brand);
    padding: 11px 24px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    transition: background 0.2s, transform 0.2s;
  }
  .teaser-starter-flat-cta:hover {
    background: var(--brand-light);
    transform: translateY(-1px);
  }
  .teaser-starter-flat-meta {
    color: var(--text-3);
    font-size: 0.76rem;
    margin-top: 8px;
  }

  .pricing-teaser-cta {
    text-align: center;
    margin-top: 32px;
  }
  .pricing-teaser-cta a {
    color: var(--brand);
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
    transition: transform 0.2s;
    display: inline-block;
  }
  .pricing-teaser-cta a:hover { transform: translateX(4px); }
</style>
