---
/**
 * Bottom-of-page cross-link block.
 * Two columns: "Related features" (siblings) + "Learn more about key features" (broader topics).
 */
export interface LinkItem {
  label: string;
  href: string;
}

export interface Props {
  related: LinkItem[];
  keyFeatures: LinkItem[];
}

const { related, keyFeatures } = Astro.props;
---

<section class="subfeat-related">
  <div class="container subfeat-related-grid">
    <div class="subfeat-related-col">
      <h3>Check out other related features</h3>
      <ul>
        {related.map((item) => (
          <li>
            <a href={item.href}>
              <span class="arrow">›</span>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="subfeat-related-col">
      <h3>Learn more about key features</h3>
      <ul>
        {keyFeatures.map((item) => (
          <li>
            <a href={item.href}>
              <span class="arrow">›</span>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>

<style>
  .subfeat-related {
    padding: 80px 0;
    background: var(--bg-alt);
  }
  .subfeat-related-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 980px;
    margin: 0 auto;
  }
  @media (max-width: 768px) {
    .subfeat-related-grid { grid-template-columns: 1fr; gap: 32px; }
  }

  .subfeat-related h3 {
    font-size: 1.05rem;
    color: var(--text);
    margin-bottom: 18px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border);
  }

  .subfeat-related ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .subfeat-related li { margin-bottom: 10px; }

  .subfeat-related li a {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--brand);
    text-decoration: none;
    font-size: 0.98rem;
    font-weight: 500;
    transition: transform 0.15s, color 0.15s;
  }
  .subfeat-related li a:hover {
    color: var(--brand-dark);
    transform: translateX(4px);
  }
  .arrow {
    color: var(--brand);
    font-size: 1.1rem;
    line-height: 1;
  }
</style>
