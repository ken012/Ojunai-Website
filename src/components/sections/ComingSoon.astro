---
export interface Props {
  page: string;
  description?: string;
}
const { page, description } = Astro.props;
---

<section class="coming-soon">
  <div class="container">
    <div class="coming-soon-card">
      <span class="coming-soon-pill">Coming soon</span>
      <h1>{page}</h1>
      {description && <p>{description}</p>}
      <p class="coming-soon-meta">
        We're rolling out the new Ojunai site page-by-page. While you wait, the homepage covers
        the essentials.
      </p>
      <a href="/" class="coming-soon-cta">← Back to homepage</a>
    </div>
  </div>
</section>

<style>
  .coming-soon { padding: 140px 0 80px; min-height: 70vh; display: flex; align-items: center; }
  .coming-soon-card {
    max-width: 580px;
    margin: 0 auto;
    text-align: center;
    background: white;
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 56px 40px;
    box-shadow: var(--shadow-lg);
  }
  .coming-soon-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .coming-soon-card h1 {
    font-size: 2.2rem;
    color: var(--text);
    margin-bottom: 12px;
  }
  .coming-soon-card p { color: var(--text-2); font-size: 1rem; line-height: 1.65; }
  .coming-soon-meta { margin-top: 18px; font-size: 0.95rem; }
  .coming-soon-cta {
    display: inline-block;
    margin-top: 32px;
    color: var(--brand);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s;
  }
  .coming-soon-cta:hover { transform: translateX(-4px); }
</style>
