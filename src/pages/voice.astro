---
import BaseLayout from '~/components/layout/BaseLayout.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';

// Tier-based Voice AI pricing. Shares the same ojunai-currency localStorage
// key as /pricing so a viewer's selection persists across both pages.
const priceMatrix = {
  voiceStarter: {
    monthly: { USD:'$39',  GBP:'£31',  NGN:'₦39,999',  GHS:'GH₵399',   KES:'KSh 3,499', ZAR:'R649',   UGX:'USh 89,000' },
    yearly:  { USD:'$390', GBP:'£310', NGN:'₦399,990', GHS:'GH₵3,990', KES:'KSh 34,990',ZAR:'R6,490', UGX:'USh 890,000' },
  },
  voicePro: {
    monthly: { USD:'$79',  GBP:'£63',  NGN:'₦82,000',  GHS:'GH₵829',   KES:'KSh 7,199', ZAR:'R1,349', UGX:'USh 180,000' },
    yearly:  { USD:'$790', GBP:'£630', NGN:'₦820,000', GHS:'GH₵8,290', KES:'KSh 71,990',ZAR:'R13,490',UGX:'USh 1,800,000' },
  },
};

const currencies = ['USD', 'GBP', 'NGN', 'GHS', 'KES', 'ZAR', 'UGX'];

const currencyMeta = {
  USD: { flag: '🇺🇸', name: 'US Dollar' },
  GBP: { flag: '🇬🇧', name: 'British Pound' },
  NGN: { flag: '🇳🇬', name: 'Nigerian Naira' },
  GHS: { flag: '🇬🇭', name: 'Ghanaian Cedi' },
  KES: { flag: '🇰🇪', name: 'Kenyan Shilling' },
  ZAR: { flag: '🇿🇦', name: 'South African Rand' },
  UGX: { flag: '🇺🇬', name: 'Ugandan Shilling' },
};

const voiceTiers = [
  {
    name: 'Voice Starter',
    priceKey: 'voiceStarter',
    priceText: priceMatrix.voiceStarter.monthly.USD,
    period: '/month',
    sub: 'For solo operators answering their own line.',
    features: [
      '300 inbound minutes / mo',
      '1 concurrent line',
      'Dedicated phone number',
      '4 languages: English, Yoruba, Hausa, Igbo',
      'Live dashboard sync',
      'Owner handoff for complex calls',
    ],
    cta: { label: 'Start with Starter', href: 'mailto:contact@ojunai.com?subject=Voice%20AI%20%E2%80%94%20Voice%20Starter' },
    featured: false,
  },
  {
    name: 'Voice Pro',
    priceKey: 'voicePro',
    priceText: priceMatrix.voicePro.monthly.USD,
    period: '/month',
    sub: 'For shops with overlapping callers and busy days.',
    features: [
      '1,000 inbound minutes / mo',
      '3 concurrent lines',
      'Dedicated phone number',
      'All 4 languages',
      'Live dashboard sync',
      'Priority call queueing + handoff',
      'Weekly call-volume report',
    ],
    cta: { label: 'Start with Pro', href: 'mailto:contact@ojunai.com?subject=Voice%20AI%20%E2%80%94%20Voice%20Pro' },
    featured: true,
    badge: 'Most Popular',
  },
  {
    name: 'Voice Enterprise',
    priceKey: null,
    priceText: 'Contact Sales',
    period: '',
    sub: 'For multi-location and high-volume operations.',
    features: [
      'Negotiated minutes',
      'Unlimited concurrent lines',
      'Multiple dedicated numbers',
      'All 4 languages + on-request additions',
      'Custom voice + tone',
      'Multi-location routing',
      'SLA-backed support',
    ],
    cta: { label: 'Talk to Sales', href: 'mailto:contact@ojunai.com?subject=Voice%20AI%20%E2%80%94%20Enterprise%20enquiry' },
    featured: false,
  },
];

const capabilities = [
  {
    title: 'Speaks 4 languages natively',
    body: 'English, Yoruba, Hausa and Igbo. Switches automatically based on the caller, or you can pin a default.',
    iconPath: 'M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zM2 12h20M12 2a15.3 15.3 0 010 20M12 2a15.3 15.3 0 000 20',
  },
  {
    title: 'Real-time stock checks',
    body: '"Do you have palm oil?" gets answered with live inventory — quantity, price, and pack size — straight from your dashboard.',
    iconPath: 'M3 6h18l-2 13H5L3 6zM3 6L2 3H0M16 10a4 4 0 01-8 0',
  },
  {
    title: 'Reservations & pickup booking',
    body: 'Customer asks to hold items? Voice AI books a reservation, sets an expiry, and confirms a pickup window.',
    iconPath: 'M3 4h18v18H3zM16 2v4M8 2v4M3 10h18',
  },
  {
    title: 'Live dashboard sync',
    body: 'Every reservation, hold, and call summary lands on your Ojunai dashboard the moment the call ends. No paperwork.',
    iconPath: 'M3 3h18v18H3zM3 9h18M9 21V3',
  },
  {
    title: 'Owner handoff',
    body: 'Caller asks something Voice AI can\'t handle? Seamless transfer to your phone — no caller dropped, no missed lead.',
    iconPath: 'M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.5 12 19.79 19.79 0 011.43 3.4 2 2 0 013.42 1.22h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L7.09 9a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z',
  },
  {
    title: '24/7 — even when closed',
    body: 'After-hours calls, lunch break, weekends. Customers hear a real assistant, not voicemail. You hear about it on WhatsApp.',
    iconPath: 'M12 2v6M12 18v4M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M18 12h4M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24',
  },
];

const setup = [
  {
    n: '01',
    title: 'You give us a phone number',
    body: 'Either we provision a new dedicated line (most common) or forward your existing business number to ours.',
  },
  {
    n: '02',
    title: 'We train Voice AI on your shop',
    body: '15-minute call with our team. We import your inventory, set your tone of voice, and define what to do when calls escalate.',
  },
  {
    n: '03',
    title: 'Go live the same day',
    body: 'Customers start calling. Every conversation lands on your Ojunai dashboard. You can listen, edit, or refine training anytime.',
  },
];

const faqs = [
  {
    q: 'How do you handle local accents?',
    a: 'Voice AI is trained on West and East African accent data — Lagos, Accra, Nairobi, Cape Town, plus regional variants like Yoruba-inflected English and Hausa-inflected English. Accuracy is verifiably higher than generic English-only assistants for African customers.',
  },
  {
    q: 'What happens to recordings?',
    a: "Each call is transcribed, summarized, and stored on your Ojunai dashboard. Audio is retained for 30 days for quality and dispute purposes, then auto-deleted. You can export or delete earlier on request.",
  },
  {
    q: 'Can I switch the AI off temporarily?',
    a: 'Yes — toggle Voice AI on or off from your dashboard or by sending "voice ai off" / "voice ai on" to the bot. Calls during off-hours fall back to your regular voicemail.',
  },
  {
    q: 'What if Voice AI gets something wrong?',
    a: 'Every call ends with an automatic transcript and summary on your dashboard. You\'re notified via WhatsApp if the AI flags low confidence. You can correct anything — refunds, reservations, pricing — directly from the dashboard.',
  },
  {
    q: 'How is this priced exactly?',
    a: 'Three tiers. Voice Starter is $39/mo and covers 300 inbound minutes with 1 concurrent line — fits a solo operator. Voice Pro is $79/mo with 1,000 minutes and 3 concurrent lines — fits a busy shop. Voice Enterprise is contact-sales with unlimited concurrent lines and negotiated minutes. All tiers include a dedicated phone number, 4-language coverage, and live dashboard sync. Annual billing saves 2 months. Outbound calls are not currently supported.',
  },
  {
    q: 'Does Voice AI come with an Ojunai plan?',
    a: 'No — Voice AI is a standalone product, sold separately from the main Ojunai tiers on /pricing. You can subscribe to Voice AI with or without an active Ojunai dashboard plan, though call data syncs to the dashboard if you have one.',
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Ojunai Voice AI',
  description:
    'A 24/7 phone receptionist that answers customer calls, confirms stock and pricing, and reserves items on your dashboard for pickup. Speaks English, Yoruba, Hausa, Igbo. Three tiers: Voice Starter, Voice Pro, Voice Enterprise.',
  brand: { '@type': 'Brand', name: 'Ojunai' },
  offers: [
    {
      '@type': 'Offer',
      name: 'Voice Starter',
      price: '39',
      priceCurrency: 'USD',
      description: '300 inbound minutes/mo, 1 concurrent line, dedicated phone number, 4 languages, live dashboard sync.',
    },
    {
      '@type': 'Offer',
      name: 'Voice Pro',
      price: '79',
      priceCurrency: 'USD',
      description: '1,000 inbound minutes/mo, 3 concurrent lines, dedicated phone number, 4 languages, priority queueing.',
    },
  ],
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="OjunaiVoice — 24/7 AI phone agents for African SMEs"
  description="A 24/7 AI phone receptionist that answers customer calls, confirms stock and pricing, and reserves items on your dashboard. Speaks English, Yoruba, Hausa, Igbo. Three tiers — Voice Starter $39, Voice Pro $79, Voice Enterprise custom."
  canonical="/voice"
  ogImage="/og/voice-ai.png"
  jsonLd={[productSchema, faqSchema]}
>
  <section class="va-hero">
    <div class="va-hero-glow"></div>
    <div class="container va-hero-inner">
      <span class="va-hero-pill">🎤 OjunaiVoice</span>
      <h1>The phone assistant that <span>never sleeps</span>.</h1>
      <p class="va-hero-sub">
        Voice AI answers your business line 24/7 — confirms stock and pricing, books reservations,
        and reserves items on your dashboard for pickup. In English, Yoruba, Hausa, or Igbo.
      </p>
      <div class="va-hero-ctas">
        <a href="#pricing" class="btn-primary">See pricing</a>
        <a href="mailto:contact@ojunai.com?subject=Voice%20AI%20%E2%80%94%20Enable%20for%20my%20business" class="va-hero-link">Talk to our team →</a>
      </div>
      <p class="va-hero-meta">
        From <strong>$39/month</strong> · Three tiers · Standalone product · Annual billing saves 2 months
      </p>
    </div>
  </section>

  <section class="va-pain">
    <div class="container va-pain-grid">
      <div class="va-pain-stat">
        <div class="va-pain-num">62%</div>
        <p>of small-business calls go unanswered during peak hours.</p>
      </div>
      <div class="va-pain-stat">
        <div class="va-pain-num">₦15k+</div>
        <p>average revenue lost per missed call for a typical provision store.</p>
      </div>
      <div class="va-pain-stat">
        <div class="va-pain-num">0</div>
        <p>missed calls when Voice AI is on. It picks up before the third ring.</p>
      </div>
    </div>
  </section>

  <section class="va-capabilities">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Capabilities</div>
        <h2>What Voice AI handles for you</h2>
      </div>
      <div class="va-capability-grid">
        {capabilities.map((c) => (
          <div class="va-capability-card">
            <div class="va-capability-icon">
              <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path d={c.iconPath} />
              </svg>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="va-pricing" id="pricing">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Pricing</div>
        <h2>Three tiers, pick what fits</h2>
        <p>Standalone product — works with or without an Ojunai dashboard plan.</p>
      </div>

      <!-- Period switcher -->
      <div class="va-period-switcher" role="tablist" aria-label="Billing period">
        <button type="button" class="va-period-pill va-period-pill-active" data-period="monthly" role="tab" aria-selected="true">Monthly</button>
        <button type="button" class="va-period-pill" data-period="yearly" role="tab" aria-selected="false">
          Yearly <span class="va-period-pill-save">Save 2 months</span>
        </button>
      </div>

      <!-- Currency flag dropdown -->
      <div class="va-currency-wrap">
        <button type="button" class="va-currency-button" aria-haspopup="listbox" aria-expanded="false" aria-label="Display currency">
          <span class="va-currency-emoji">🇺🇸</span>
          <span class="va-currency-code">USD</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" aria-hidden="true">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
        <ul class="va-currency-dropdown" role="listbox" hidden>
          {currencies.map((c) => (
            <li>
              <button type="button" class={`va-currency-option ${c === 'USD' ? 'va-currency-option-active' : ''}`} data-ccy={c} role="option" aria-selected={c === 'USD' ? 'true' : 'false'}>
                <span class="va-currency-emoji">{currencyMeta[c].flag}</span>
                <span class="va-currency-code">{c}</span>
                <span class="va-currency-name">{currencyMeta[c].name}</span>
              </button>
            </li>
          ))}
        </ul>
      </div>

      <div class="va-tier-grid">
        {voiceTiers.map((t) => (
          <div class={`va-tier ${t.featured ? 'va-tier-featured' : ''}`}>
            {t.badge && <div class="va-tier-badge">{t.badge}</div>}
            <div class="va-tier-name">{t.name}</div>
            <div class="va-tier-price">
              {t.priceKey
                ? <span data-price-id={t.priceKey}>{t.priceText}</span>
                : <span>{t.priceText}</span>}
              {t.period && <span class="va-tier-period js-period-text">{t.period}</span>}
            </div>
            <div class="js-usd-ref" data-price-id={t.priceKey} hidden></div>
            <div class="va-tier-sub">{t.sub}</div>
            <ul class="va-tier-features">
              {t.features.map((f) => <li>{f}</li>)}
            </ul>
            <a href={t.cta.href} class={`va-tier-cta ${t.featured ? 'va-tier-cta-primary' : ''}`}>{t.cta.label}</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <script type="application/json" id="ojunai-voice-price-matrix" set:html={JSON.stringify(priceMatrix)} />

  <script is:inline>
    (function () {
      const SUPPORTED = ['USD','GBP','NGN','GHS','KES','ZAR','UGX'];
      const FLAGS = { USD:'🇺🇸', GBP:'🇬🇧', NGN:'🇳🇬', GHS:'🇬🇭', KES:'🇰🇪', ZAR:'🇿🇦', UGX:'🇺🇬' };
      const TZ_TO_CCY = {
        'Africa/Lagos':'NGN','Africa/Abuja':'NGN','Africa/Port_Harcourt':'NGN','Africa/Kano':'NGN',
        'Africa/Accra':'GHS',
        'Africa/Nairobi':'KES','Africa/Mombasa':'KES',
        'Africa/Johannesburg':'ZAR','Africa/Cape_Town':'ZAR','Africa/Durban':'ZAR',
        'Africa/Kampala':'UGX',
        'Europe/London':'GBP','Europe/Belfast':'GBP','Europe/Jersey':'GBP','Europe/Guernsey':'GBP','Europe/Isle_of_Man':'GBP'
      };
      const REGION_TO_CCY = { NG:'NGN', GH:'GHS', KE:'KES', ZA:'ZAR', UG:'UGX', GB:'GBP', IM:'GBP', JE:'GBP', GG:'GBP' };

      function detectCurrency() {
        try {
          const stored = localStorage.getItem('ojunai-currency');
          if (stored && SUPPORTED.indexOf(stored) >= 0) return stored;
        } catch (e) {}
        try {
          const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
          if (TZ_TO_CCY[tz]) return TZ_TO_CCY[tz];
        } catch (e) {}
        try {
          const lang = navigator.language || 'en-US';
          const region = (lang.split('-')[1] || '').toUpperCase();
          if (REGION_TO_CCY[region]) return REGION_TO_CCY[region];
        } catch (e) {}
        return 'USD';
      }

      function detectPeriod() {
        try {
          const s = localStorage.getItem('ojunai-billing-period');
          if (s === 'monthly' || s === 'yearly') return s;
        } catch (e) {}
        return 'monthly';
      }

      let matrix = {};
      try {
        const n = document.getElementById('ojunai-voice-price-matrix');
        matrix = n ? JSON.parse(n.textContent) : {};
      } catch (e) { matrix = {}; }

      function lookup(key, period, ccy) {
        const item = matrix[key];
        if (!item) return null;
        if (item[period] && item[period][ccy]) return item[period][ccy];
        if (item.monthly && item.monthly[ccy]) return item.monthly[ccy];
        return null;
      }
      function lookupUsd(key, period) {
        const item = matrix[key];
        if (!item) return null;
        if (item[period] && item[period].USD) return item[period].USD;
        if (item.monthly && item.monthly.USD) return item.monthly.USD;
        return null;
      }

      let activeCcy = 'USD';
      let activePeriod = 'monthly';

      function applyAll() {
        document.querySelectorAll('[data-price-id]').forEach(function (el) {
          const key = el.getAttribute('data-price-id');
          const v = lookup(key, activePeriod, activeCcy);
          if (v != null) el.textContent = v;
        });
        document.querySelectorAll('.js-period-text').forEach(function (el) {
          el.textContent = activePeriod === 'yearly' ? '/year' : '/month';
        });
        document.querySelectorAll('.js-usd-ref').forEach(function (el) {
          const key = el.getAttribute('data-price-id');
          const usd = lookupUsd(key, activePeriod);
          if (activeCcy === 'USD' || !usd || !key) { el.hidden = true; return; }
          el.textContent = '≈ ' + usd + ' USD';
          el.hidden = false;
        });
      }

      function applyCurrency(ccy) {
        if (SUPPORTED.indexOf(ccy) < 0) ccy = 'USD';
        activeCcy = ccy;
        applyAll();
        const btn = document.querySelector('.va-currency-button');
        if (btn) {
          const emoji = btn.querySelector('.va-currency-emoji');
          const code = btn.querySelector('.va-currency-code');
          if (emoji) emoji.textContent = FLAGS[ccy] || '🌐';
          if (code) code.textContent = ccy;
        }
        document.querySelectorAll('.va-currency-option').forEach(function (o) {
          const active = o.getAttribute('data-ccy') === ccy;
          o.classList.toggle('va-currency-option-active', active);
          o.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        try { localStorage.setItem('ojunai-currency', ccy); } catch (e) {}
      }

      function applyPeriod(period) {
        if (period !== 'monthly' && period !== 'yearly') period = 'monthly';
        activePeriod = period;
        applyAll();
        document.querySelectorAll('.va-period-pill').forEach(function (b) {
          const active = b.getAttribute('data-period') === period;
          b.classList.toggle('va-period-pill-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        try { localStorage.setItem('ojunai-billing-period', period); } catch (e) {}
      }

      function init() {
        activeCcy = detectCurrency();
        activePeriod = detectPeriod();
        applyCurrency(activeCcy);
        applyPeriod(activePeriod);
        const btn = document.querySelector('.va-currency-button');
        const list = document.querySelector('.va-currency-dropdown');
        if (btn && list) {
          btn.addEventListener('click', function () {
            const open = !list.hasAttribute('hidden');
            if (open) { list.setAttribute('hidden', ''); btn.setAttribute('aria-expanded', 'false'); }
            else { list.removeAttribute('hidden'); btn.setAttribute('aria-expanded', 'true'); }
          });
          document.addEventListener('click', function (ev) {
            if (!btn.contains(ev.target) && !list.contains(ev.target)) {
              list.setAttribute('hidden', '');
              btn.setAttribute('aria-expanded', 'false');
            }
          });
          document.querySelectorAll('.va-currency-option').forEach(function (o) {
            o.addEventListener('click', function () {
              applyCurrency(o.getAttribute('data-ccy'));
              list.setAttribute('hidden', '');
              btn.setAttribute('aria-expanded', 'false');
            });
          });
        }
        document.querySelectorAll('.va-period-pill').forEach(function (b) {
          b.addEventListener('click', function () { applyPeriod(b.getAttribute('data-period')); });
        });
      }

      if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
      else init();
    })();
  </script>

  <section class="va-setup">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Setup</div>
        <h2>Live in one day, not one quarter</h2>
      </div>
      <div class="va-setup-steps">
        {setup.map((s) => (
          <div class="va-setup-step">
            <div class="va-setup-num">{s.n}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="va-faq">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Frequently Asked</div>
        <h2>Voice AI questions</h2>
      </div>
      <div class="va-faq-list">
        {faqs.map((f) => (
          <details class="va-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>

<style>
  /* ============ HERO ============ */
  .va-hero {
    position: relative;
    overflow: hidden;
    padding: 160px 0 100px;
    background: radial-gradient(120% 140% at 30% 0%, #1E1B4B 0%, #0B0B22 60%, #030310 100%);
    color: white;
  }
  .va-hero-glow {
    position: absolute;
    top: -150px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(129, 140, 248, 0.4), transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }
  .va-hero-inner { position: relative; max-width: 760px; }
  .va-hero-pill {
    display: inline-block;
    background: rgba(99, 102, 241, 0.2);
    color: #C7D2FE;
    border: 1px solid rgba(165, 180, 252, 0.35);
    padding: 7px 16px;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .va-hero h1 {
    font-size: clamp(2.4rem, 5.5vw, 4.2rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
  }
  .va-hero h1 span {
    background: linear-gradient(90deg, #A5B4FC 0%, #38BDF8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .va-hero-sub {
    font-size: 1.2rem;
    line-height: 1.6;
    color: #CBD5E1;
    margin-bottom: 36px;
    max-width: 620px;
  }
  .va-hero-ctas {
    display: flex;
    align-items: center;
    gap: 24px;
    margin-bottom: 28px;
    flex-wrap: wrap;
  }
  .va-hero-link {
    color: #C7D2FE;
    font-weight: 600;
    text-decoration: none;
