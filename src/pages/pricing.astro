  <!-- Currency price matrix as JSON island for client-side swap -->
  <script type="application/json" id="ojunai-price-matrix" set:html={JSON.stringify(priceMatrix)} />

  <script is:inline>
    (function () {
      const SUPPORTED = ['USD','GBP','NGN','GHS','KES','ZAR','UGX'];
      const FLAGS = { USD:'🇺🇸', GBP:'🇬🇧', NGN:'🇳🇬', GHS:'🇬🇭', KES:'🇰🇪', ZAR:'🇿🇦', UGX:'🇺🇬' };
      const TZ_TO_CCY = {
        'Africa/Lagos':'NGN','Africa/Abuja':'NGN','Africa/Port_Harcourt':'NGN','Africa/Kano':'NGN',
        'Africa/Accra':'GHS',
        'Africa/Nairobi':'KES','Africa/Mombasa':'KES',
        'Africa/Johannesburg':'ZAR','Africa/Cape_Town':'ZAR','Africa/Durban':'ZAR',
        'Africa/Kampala':'UGX',
        'Europe/London':'GBP','Europe/Belfast':'GBP','Europe/Jersey':'GBP','Europe/Guernsey':'GBP','Europe/Isle_of_Man':'GBP'
      };
      const REGION_TO_CCY = { NG:'NGN', GH:'GHS', KE:'KES', ZA:'ZAR', UG:'UGX', GB:'GBP', IM:'GBP', JE:'GBP', GG:'GBP' };

      function detectCurrency() {
        try {
          const stored = localStorage.getItem('ojunai-currency');
          if (stored && SUPPORTED.indexOf(stored) >= 0) return stored;
        } catch (e) {}
        try {
          const tz = Intl.DateTimeFormat().resolvedOptions().timeZone;
          if (TZ_TO_CCY[tz]) return TZ_TO_CCY[tz];
        } catch (e) {}
        try {
          const lang = navigator.language || 'en-US';
          const region = (lang.split('-')[1] || '').toUpperCase();
          if (REGION_TO_CCY[region]) return REGION_TO_CCY[region];
        } catch (e) {}
        return 'USD';
      }

      function detectPeriod() {
        try {
          const stored = localStorage.getItem('ojunai-billing-period');
          if (stored === 'monthly' || stored === 'yearly') return stored;
        } catch (e) {}
        return 'monthly';
      }

      let matrix = {};
      try {
        const node = document.getElementById('ojunai-price-matrix');
        matrix = node ? JSON.parse(node.textContent) : {};
      } catch (e) { matrix = {}; }

      // Lookup that handles both nested {monthly,yearly} entries and flat
      // entries (one-time/no-yearly items). Falls back gracefully.
      function lookup(key, period, ccy) {
        const item = matrix[key];
        if (!item) return null;
        if (item[period] && item[period][ccy]) return item[period][ccy];
        if (item[ccy]) return item[ccy];
        if (item.monthly && item.monthly[ccy]) return item.monthly[ccy];
        return null;
      }

      let activeCcy = 'USD';
      let activePeriod = 'monthly';

      // Look up the USD value for a given priced item — used for the "≈ $XX USD" reference line
      // shown beneath non-USD prices. Falls back to monthly for items without a period split.
      function lookupUsd(key, period) {
        const item = matrix[key];
        if (!item) return null;
        if (item[period] && item[period].USD) return item[period].USD;
        if (item.USD) return item.USD;
        if (item.monthly && item.monthly.USD) return item.monthly.USD;
        return null;
      }

      function applyAll() {
        document.querySelectorAll('[data-price-id]').forEach(function (el) {
          const key = el.getAttribute('data-price-id');
          const v = lookup(key, activePeriod, activeCcy);
          if (v != null) el.textContent = v;
        });
        document.querySelectorAll('.js-period-text').forEach(function (el) {
          // Per-element period text — but don't rewrite PAYG card periods (those are one-time, no /mo or /year)
          if (el.dataset.staticPeriod === 'true') return;
          el.textContent = activePeriod === 'yearly' ? '/year' : '/month';
        });
        // Update the USD reference labels — hide for USD, show "≈ $XX USD" otherwise
        document.querySelectorAll('.js-usd-ref').forEach(function (el) {
          const key = el.getAttribute('data-price-id');
          const usd = lookupUsd(key, activePeriod);
          if (activeCcy === 'USD' || !usd) {
            el.hidden = true;
            return;
          }
          el.textContent = '≈ ' + usd + ' USD';
          el.hidden = false;
        });
      }

      function applyCurrency(ccy) {
        if (SUPPORTED.indexOf(ccy) < 0) ccy = 'USD';
        activeCcy = ccy;
        applyAll();
        // Update flag-button display
        const flagBtn = document.querySelector('.currency-flag-button');
        if (flagBtn) {
          const emoji = flagBtn.querySelector('.currency-flag-emoji');
          const code = flagBtn.querySelector('.currency-flag-code');
          if (emoji) emoji.textContent = FLAGS[ccy] || '🌐';
          if (code) code.textContent = ccy;
        }
        // Dropdown active-row marker
        document.querySelectorAll('.currency-flag-option').forEach(function (opt) {
          const active = opt.getAttribute('data-ccy') === ccy;
          opt.classList.toggle('currency-flag-option-active', active);
          opt.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        try { localStorage.setItem('ojunai-currency', ccy); } catch (e) {}
      }

      function applyPeriod(period) {
        if (period !== 'monthly' && period !== 'yearly') period = 'monthly';
        activePeriod = period;
        applyAll();
        document.querySelectorAll('.period-pill').forEach(function (b) {
          const active = b.getAttribute('data-period') === period;
          b.classList.toggle('period-pill-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        try { localStorage.setItem('ojunai-billing-period', period); } catch (e) {}
      }

      function wireDropdown() {
        const btn = document.querySelector('.currency-flag-button');
        const list = document.querySelector('.currency-flag-dropdown');
        if (!btn || !list) return;
        btn.addEventListener('click', function () {
          const open = list.hasAttribute('hidden') ? false : true;
          if (open) {
            list.setAttribute('hidden', '');
            btn.setAttribute('aria-expanded', 'false');
          } else {
            list.removeAttribute('hidden');
            btn.setAttribute('aria-expanded', 'true');
          }
        });
        document.addEventListener('click', function (ev) {
          if (!btn.contains(ev.target) && !list.contains(ev.target)) {
            list.setAttribute('hidden', '');
            btn.setAttribute('aria-expanded', 'false');
          }
        });
        document.querySelectorAll('.currency-flag-option').forEach(function (opt) {
          opt.addEventListener('click', function () {
            applyCurrency(opt.getAttribute('data-ccy'));
            list.setAttribute('hidden', '');
            btn.setAttribute('aria-expanded', 'false');
          });
        });
      }

      function wirePaygTabs() {
        document.querySelectorAll('.payg-tab').forEach(function (tab) {
          tab.addEventListener('click', function () {
            const id = tab.getAttribute('data-payg-tab');
            document.querySelectorAll('.payg-tab').forEach(function (t) {
              const active = t.getAttribute('data-payg-tab') === id;
              t.classList.toggle('payg-tab-active', active);
              t.setAttribute('aria-selected', active ? 'true' : 'false');
            });
            document.querySelectorAll('.payg-panel').forEach(function (p) {
              if (p.getAttribute('data-payg-panel') === id) p.removeAttribute('hidden');
              else p.setAttribute('hidden', '');
            });
          });
        });
      }

      function init() {
        activeCcy = detectCurrency();
        activePeriod = detectPeriod();
        applyCurrency(activeCcy);
        applyPeriod(activePeriod);
        wireDropdown();
        wirePaygTabs();
        document.querySelectorAll('.period-pill').forEach(function (b) {
          b.addEventListener('click', function () { applyPeriod(b.getAttribute('data-period')); });
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>
</BaseLayout>

