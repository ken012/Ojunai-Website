// ====================================
// FAQ
// ====================================
const faqs = [
  {
    q: 'How does the free Starter plan work?',
    a: 'Starter is free forever — no credit card required. You get core inventory tracking, sales logging, expense tracking, and basic reports for one user. Upgrade any time when you need debt tracking, WhatsApp Assistant, multi-user, or advanced reports.',
  },
  {
    q: 'What\'s a "business action"?',
    a: 'A business action is one operational interaction with the WhatsApp Assistant — recording a sale, adding stock, logging an expense, requesting a report, sending a receipt, or any equivalent task. Reading-only queries (like "what\'s my stock?") count as actions when they trigger a response. Casual chat and clarifications usually don\'t.',
  },
  {
    q: 'What happens when I run out of weekly business actions?',
    a: 'WhatsApp Assistant pauses for the week and you receive a notification. You can buy a usage pack any time to top up immediately, or upgrade your plan to a higher tier. Your dashboard remains fully usable regardless.',
  },
  {
    q: 'How do the WhatsApp Business OS tiers (Solo / Pro / Scale) differ?',
    a: 'WhatsApp Business OS replaces the dashboard with a single WhatsApp conversation. Solo ($49.99/mo) covers 1 user, 1 location, 100 SKUs, 50 PDFs/month, and 1,200 business actions/month — best for solo shopkeepers running everything by chat. Pro ($145.99/mo) covers 3 users, unlimited SKUs and PDFs, 6,000 actions/month, branded PDF templates, and bulk announcements — best for established small businesses. Scale (Contact Sales) covers 6+ users, multi-location, unlimited actions, custom PDF templates per type, an optional Voice AI bundle, and 1+ year history retention. All three sit on top of any base plan (Starter through Scale).',
  },
  {
    q: 'Can I add Voice AI or other add-ons to any plan?',
    a: 'Most add-ons work with any plan from Operator upward. Voice AI specifically is available on every plan including Starter — it\'s billed as a standalone subscription on top of your base plan.',
  },
  {
    q: 'How do I switch plans?',
    a: 'Upgrade or downgrade any time from the dashboard. Upgrades take effect immediately and we prorate the difference. Downgrades take effect at the end of your current billing period so you keep paid features until then.',
  },
  {
    q: 'What payment methods are supported?',
    a: 'Cards (Visa, Mastercard, Verve, Amex), bank transfers, and mobile money. We work across African and global markets through trusted payment providers. See the Payments & Billing section below for more.',
  },
  {
    q: 'Which currencies can I be billed in?',
    a: 'USD, NGN (Nigerian Naira), GHS (Ghanaian Cedi), KES (Kenyan Shilling), ZAR (South African Rand), UGX (Ugandan Shilling), and GBP (British Pound) — pick whichever suits your business. We auto-detect a sensible default based on your region; you can override the currency at the top of this page.',
  },
  {
    q: 'Do you offer refunds?',
    a: 'Subscription fees are non-refundable, and we don\'t partial-refund unused time within a billing period. If something\'s wrong with a charge, email contact@ojunai.com and we\'ll work with our payment provider to fix it.',
  },
  {
    q: 'Can I get a custom Enterprise plan?',
    a: 'Yes. Enterprise covers 10+ users, multi-region rollouts, custom WhatsApp limits, dedicated onboarding, API access, and SLA-backed support. Email contact@ojunai.com to start the conversation.',
  },
  {
    q: 'Is there a discount for annual billing?',
    a: 'Annual billing is available on every paid plan with a discount equivalent to roughly 2 months free. Talk to sales for the exact figure on your tier.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="Pricing — Ojunai"
  description="Run your business operating system on Ojunai. Free Starter, Lite $12.99, Operator $29, Professional $79, Scale $199, custom Enterprise. WhatsApp business actions included from Lite up. Pay in USD, NGN, GHS, KES, ZAR, UGX, or GBP."
  canonical="/pricing"
  ogImage="/og/pricing.png"
  jsonLd={faqSchema}
>
  <!-- HERO -->
  <section class="pricing-hero">
    <div class="container pricing-hero-inner">
      <span class="pricing-hero-pill">Pricing</span>
      <h1>Plans that scale with your business.</h1>
      <p>
        Start free. Upgrade as you grow. Pay only for what you actually use —
        with WhatsApp business actions, multi-user, and add-ons priced à la carte.
      </p>

      <!-- Currency switcher -->
      <div class="currency-switcher" role="tablist" aria-label="Display currency">
        <span class="currency-switcher-label">Show prices in</span>
        <div class="currency-switcher-pills">
          {currencies.map((c) => (
            <button
              type="button"
              class={`currency-pill ${c === 'USD' ? 'currency-pill-active' : ''}`}
              data-ccy={c}
              role="tab"
              aria-selected={c === 'USD' ? 'true' : 'false'}
            >
              {c}
            </button>
          ))}
        </div>
      </div>

      <p class="pricing-hero-meta">
        <span class="pricing-hero-meta-currency">Showing prices in USD.</span>
        Annual billing available. <a href="#payments">Local payment methods supported.</a>
      </p>
    </div>
  </section>

  <!-- PLAN CARDS -->
  <section class="pricing-cards-section">
    <div class="container">
      <div class="pricing-cards-grid">
        {plans.map((p) => (
          <div class={`price-card-v2 ${p.featured ? 'price-card-v2-featured' : ''}`}>
            {p.badge && <div class="price-card-v2-badge">{p.badge}</div>}
            <div class="price-card-v2-header">
              <div class="price-card-v2-name">{p.name}</div>
              <div class="price-card-v2-price">
                {p.priceKey
                  ? <span data-price-id={p.priceKey}>{p.priceText}</span>
                  : p.priceText}
                {p.period && <span class="price-card-v2-period">{p.period}</span>}
              </div>
              <div class="price-card-v2-sub">{p.sub}</div>
            </div>
            <ul class="price-card-v2-features">
              {p.features.map((f) => (
                <li>
                  <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.4" viewBox="0 0 24 24" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  {f}
                </li>
              ))}
            </ul>
            <a
              href={p.cta.href}
              target={p.cta.external ? '_blank' : undefined}
              rel={p.cta.external ? 'noopener' : undefined}
              class={`price-card-v2-cta ${p.cta.variant === 'primary' ? 'price-card-v2-cta-primary' : 'price-card-v2-cta-outline'}`}
            >
              {p.cta.label}
            </a>
          </div>
        ))}
      </div>

      <!-- STARTER FLAT CARD -->
      <div class="starter-flat-card">
        <div class="starter-flat-meta">
          <div class="starter-flat-pill">Starter</div>
          <h3>{starterFlat.sub}</h3>
          <ul class="starter-flat-features">
            {starterFlat.features.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="starter-flat-cta-col">
          <div class="starter-flat-price">{starterFlat.priceText}</div>
          <a href={starterFlat.cta.href} target="_blank" rel="noopener" class="starter-flat-cta">
            {starterFlat.cta.label}
          </a>
          <p class="starter-flat-cta-meta">No credit card required</p>
        </div>
      </div>

      <!-- ENTERPRISE -->
      <div class="enterprise-card">
        <div class="enterprise-meta">
          <div class="enterprise-pill">Enterprise</div>
          <h3>{enterprise.sub}</h3>
          <p class="enterprise-price">{enterprise.price}</p>
          <ul class="enterprise-features">
            {enterprise.features.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="enterprise-cta-col">
          <a href="mailto:contact@ojunai.com?subject=Ojunai%20Enterprise%20plan%20inquiry" class="enterprise-cta">
            Contact Sales
          </a>
          <p class="enterprise-cta-meta">Reply within 1 business day · contact@ojunai.com</p>
        </div>
