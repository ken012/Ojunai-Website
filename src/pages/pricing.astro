<BaseLayout
  title="Pricing — Ojunai"
  description="Simple, fair pricing for African SMEs. Use the dashboard free. Add the channels you need (Telegram, Messenger, WhatsApp). Pay for what you use. Lite from $11.99/mo, Operator $28.99, Pro $69.99, Scale $149.99, custom Enterprise. Bill in USD, GBP, NGN, GHS, KES, ZAR, or UGX."
  canonical="/pricing"
  ogImage="/og/pricing.png"
  jsonLd={faqSchema}
>
  <!-- HERO -->
