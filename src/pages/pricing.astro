// ====================================
// FAQ
// ====================================
const faqs = [
  {
    q: 'How does the free Starter plan work?',
    a: 'Starter is free forever — no credit card required. You get core inventory tracking, sales logging, expense tracking, basic reports, and 15 total Assistant actions per month across Telegram, Messenger, or WhatsApp combined. Upgrade any time when you need more capacity, debt tracking, multi-user, or advanced reports.',
  },
  {
    q: 'What\'s a "business action"?',
    a: 'A business action is one operational interaction with the Assistant on any channel — recording a sale, adding stock, logging an expense, requesting a report, sending a receipt, or any equivalent task. Reading-only queries (like "what\'s my stock?") count as actions when they trigger a response. Casual chat and clarifications usually don\'t.',
  },
  {
    q: 'Why does WhatsApp need its own pack while Telegram & Messenger are included in tiers?',
    a: 'Telegram and Messenger don\'t charge per-message fees. WhatsApp does — Meta charges per conversation, which we have to pass through. The pack model lets you pick exactly how much WhatsApp volume you need without inflating every tier. Telegram + Messenger quotas are 5× larger than WhatsApp at every tier and unlimited at Scale.',
  },
  {
    q: 'What happens when I run out of monthly actions?',
    a: 'The Assistant for that channel pauses and you receive a notification. You can buy a one-time top-up pack any time (Boost / Top-Up / Power), upgrade your tier, or upgrade your WhatsApp pack. The dashboard stays fully usable regardless.',
  },
  {
    q: 'What about Voice AI?',
    a: 'Voice AI is a standalone product on its own page — see ojunai.com/voice. It\'s billed as a separate subscription and sold on its own to keep this pricing focused on chat operations.',
  },
  {
    q: 'How do I switch tiers or change WhatsApp packs?',
    a: 'Upgrade or downgrade any time from the dashboard. Upgrades take effect immediately and we prorate the difference. Downgrades take effect at the end of your current billing period.',
  },
  {
    q: 'What payment methods are supported?',
    a: 'Cards (Visa, Mastercard, Verve, Amex), bank transfers, and mobile money. We work across African and global markets through trusted payment providers — see the Payments & Billing section below.',
  },
  {
    q: 'Why are African prices lower than direct USD conversion?',
    a: 'We price for purchasing power, not just FX. Specifically: ZAR is about 10% below direct USD conversion; NGN, GHS, and KES about 30% below; UGX about 40% below. Add-ons stay USD-anchored. We freeze local amounts at launch and revisit quarterly.',
  },
  {
    q: 'Which currencies can I be billed in?',
    a: 'USD, GBP, NGN, GHS, KES, ZAR, and UGX. We auto-detect a sensible default; flip the flag dropdown at the top of this page to switch.',
  },
  {
    q: 'Do you offer refunds?',
    a: 'Subscription fees are non-refundable, and we don\'t partial-refund unused time within a billing period. If something\'s wrong with a charge, email contact@ojunai.com.',
  },
  {
    q: 'Can I get a custom Enterprise plan?',
    a: 'Yes. Enterprise covers 10+ users, multi-region rollouts, unlimited channel capacity (Telegram, Messenger, WhatsApp), dedicated onboarding, API access, and SLA-backed support. Email contact@ojunai.com to start.',
  },
  {
    q: 'Is there a discount for annual billing?',
    a: 'Annual billing is available on every paid tier and every WhatsApp pack with a discount equivalent to 2 months free (10× monthly). Toggle Monthly ↔ Yearly at the top of the page.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
