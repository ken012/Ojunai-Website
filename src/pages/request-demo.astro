---
import BaseLayout from '~/components/layout/BaseLayout.astro';

/**
 * Request-a-demo page.
 *
 * Form is wired to Netlify Forms (https://docs.netlify.com/forms/setup/).
 * After deploy:
 *   - Submissions appear in Netlify dashboard → Forms tab
 *   - Set up email notifications: Site → Forms → Notifications
 *   - Spam filtering: honeypot field below catches most bots automatically
 *   - hCaptcha: replace `PUBLIC_HCAPTCHA_SITEKEY` env var with your real sitekey
 *     (free at https://www.hcaptcha.com — never use the test key in production
 *     for spam protection)
 *
 * The static form below is duplicated as `_form-request-demo.html` style detection
 * — Netlify's build crawler scans HTML for `data-netlify="true"` and registers
 * the form automatically; no extra config needed.
 */
const hcaptchaSitekey =
  import.meta.env.PUBLIC_HCAPTCHA_SITEKEY ||
  // hCaptcha public test key — always succeeds. SAFE FOR DEV, NOT PROD.
  '10000000-ffff-ffff-ffff-000000000001';

const isUsingTestKey = hcaptchaSitekey === '10000000-ffff-ffff-ffff-000000000001';
---

<BaseLayout
  title="Request a demo — Ojunai"
  description="Walk through Ojunai with one of our team. Tell us about your business and we'll show you exactly how the dashboard, WhatsApp AI and Voice AI fit your day-to-day."
  canonical="/request-demo"
>
  <section class="demo-hero">
    <div class="container demo-hero-inner">
      <span class="demo-hero-pill">Live walkthrough</span>
      <h1>See Ojunai in action.</h1>
      <p>
        Tell us a bit about your business and we'll book a 20-minute walkthrough — dashboard,
        WhatsApp AI, Voice AI, and how it fits your workflow. African team, African business hours.
      </p>
    </div>
  </section>

  <section class="demo-form-section">
    <div class="container demo-form-grid">
      <aside class="demo-aside">
        <h2>What to expect</h2>
        <ul>
          <li>
            <strong>20-minute call</strong> — focused on your specific industry and team size.
          </li>
          <li>
            <strong>Live dashboard demo</strong> — we share the screen, show real flows.
          </li>
          <li>
            <strong>Honest Q&amp;A</strong> — pricing, integrations, migration from your current tools.
          </li>
          <li>
            <strong>No pressure</strong> — try Ojunai's free month right after if it's a fit.
          </li>
        </ul>

        <div class="demo-aside-contact">
          <strong>Prefer email?</strong>
          <p>
            <a href="mailto:contact@ojunai.com?subject=Demo%20request">contact@ojunai.com</a>
          </p>
          <strong>Just want to start?</strong>
          <p>
            <a href="https://app.ojunai.com/register" target="_blank" rel="noopener">
              Sign up free →
            </a>
          </p>
        </div>
      </aside>

      <form
        class="demo-form"
        name="request-demo"
        method="POST"
        action="/request-demo?success=1"
        data-netlify="true"
        data-netlify-honeypot="bot-field"
      >
        {/* Tells Netlify which form this is when JS-disabled */}
        <input type="hidden" name="form-name" value="request-demo" />

        {/* Honeypot — invisible to users, bots fill it in and get rejected */}
        <p class="demo-form-honeypot" aria-hidden="true">
          <label>Don't fill this out: <input name="bot-field" tabindex="-1" autocomplete="off" /></label>
        </p>

        <div class="demo-field">
          <label for="name">Your name</label>
          <input
            id="name"
            name="name"
            type="text"
            required
            autocomplete="name"
            placeholder="Amara Mensah"
          />
        </div>

        <div class="demo-field">
          <label for="email">Business email</label>
          <input
            id="email"
            name="email"
            type="email"
            required
            autocomplete="email"
            placeholder="amara@yourshop.com"
          />
        </div>

        <div class="demo-field">
          <label for="phone">Phone (with country code)</label>
          <input
            id="phone"
            name="phone"
            type="tel"
            required
            autocomplete="tel"
            placeholder="+234 800 000 0000"
          />
        </div>

        <div class="demo-field">
          <label for="message">Tell us what you're looking for</label>
          <textarea
            id="message"
            name="message"
            rows="5"
            required
            placeholder="A quick line about your business — what you sell, how big the team is, what tools you use today, what you'd love Ojunai to do."
          ></textarea>
        </div>

        <div class="demo-captcha-row">
          <div class="h-captcha" data-sitekey={hcaptchaSitekey}></div>
        </div>

        {isUsingTestKey && (
          <p class="demo-captcha-note">
            ⚠️ hCaptcha is using a public test key. Sign up at
            <a href="https://www.hcaptcha.com" target="_blank" rel="noopener">hcaptcha.com</a>
            and set <code>PUBLIC_HCAPTCHA_SITEKEY</code> in your env vars before going live with paid traffic.
          </p>
        )}

        <button type="submit" class="demo-submit">Request demo</button>

        <p class="demo-form-disclaimer">
          By submitting, you agree to our
          <a href="/privacy">Privacy Policy</a>. We'll only use your details to schedule the demo.
        </p>
      </form>
    </div>
  </section>

  {Astro.url.searchParams.get('success') && (
    <section class="demo-success">
      <div class="container demo-success-inner">
        <div class="demo-success-card">
          <span class="demo-success-icon">✓</span>
          <h2>Got it — we'll be in touch within one business day.</h2>
          <p>
            Watch your inbox at the email you provided. We'll send a calendar link with a few time
            slots that match West African business hours.
          </p>
          <a href="/" class="demo-success-back">← Back to homepage</a>
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<script src="https://js.hcaptcha.com/1/api.js" async defer></script>

<style>
  .demo-hero {
    padding: 160px 0 60px;
    background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg) 100%);
    text-align: center;
  }
  .demo-hero-inner { max-width: 720px; margin: 0 auto; }
  .demo-hero-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .demo-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text);
  }
  .demo-hero p {
    font-size: 1.1rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .demo-form-section {
    padding: 60px 0 100px;
    background: var(--bg);
  }
  .demo-form-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: 56px;
    max-width: 1040px;
    margin: 0 auto;
    align-items: start;
  }
  @media (max-width: 880px) {
    .demo-form-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .demo-aside h2 {
    font-size: 1.15rem;
    margin-bottom: 16px;
    color: var(--text);
  }
  .demo-aside ul {
    list-style: none;
    padding: 0;
    margin-bottom: 32px;
  }
  .demo-aside li {
    padding: 10px 0 10px 28px;
    position: relative;
    color: var(--text-2);
    font-size: 0.95rem;
    line-height: 1.55;
  }
  .demo-aside li::before {
    content: '✓';
    position: absolute;
    left: 0;
    top: 11px;
    color: var(--brand);
    font-weight: 700;
  }
  .demo-aside strong { color: var(--text); }

  .demo-aside-contact {
    border-top: 1px solid var(--border);
    padding-top: 24px;
    font-size: 0.9rem;
  }
  .demo-aside-contact strong { display: block; margin-top: 12px; color: var(--text-2); font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.06em; }
  .demo-aside-contact p { margin: 4px 0 12px; }
  .demo-aside-contact a {
    color: var(--brand);
    text-decoration: none;
    font-weight: 600;
  }
  .demo-aside-contact a:hover { text-decoration: underline; }

  .demo-form {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    box-shadow: var(--shadow);
  }

  .demo-form-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .demo-field {
    margin-bottom: 18px;
  }
  .demo-field label {
    display: block;
    font-weight: 600;
    color: var(--text);
    font-size: 0.92rem;
    margin-bottom: 6px;
  }
  .demo-field input,
  .demo-field textarea {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--text);
    background: var(--bg);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .demo-field input:focus,
  .demo-field textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.15);
    background: white;
  }
  .demo-field textarea {
    resize: vertical;
    min-height: 110px;
  }

  .demo-captcha-row {
    margin: 20px 0 12px;
    display: flex;
    justify-content: flex-start;
  }

  .demo-captcha-note {
    font-size: 0.78rem;
    color: var(--text-3);
    background: rgba(245, 158, 11, 0.08);
    border-left: 3px solid #F59E0B;
    padding: 8px 12px;
    border-radius: 6px;
    margin-bottom: 16px;
  }
  .demo-captcha-note a {
    color: var(--brand);
    text-decoration: underline;
  }
  .demo-captcha-note code {
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 0.74rem;
    background: rgba(0, 0, 0, 0.05);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .demo-submit {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 28px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1rem;
    text-decoration: none;
    background: linear-gradient(135deg, #6366F1, #4F46E5);
    color: white;
    border: none;
    cursor: pointer;
    box-shadow: 0 6px 20px rgba(99, 102, 241, 0.35);
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .demo-submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 28px rgba(99, 102, 241, 0.5);
  }
  .demo-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
    box-shadow: none;
  }

  .demo-form-disclaimer {
    font-size: 0.82rem;
    color: var(--text-3);
    margin-top: 14px;
    line-height: 1.5;
  }
  .demo-form-disclaimer a {
    color: var(--brand);
    text-decoration: underline;
  }

  /* SUCCESS STATE — appears after the form when ?success=1 in URL */
  .demo-success {
    padding: 80px 0;
    background: var(--bg-alt);
  }
  .demo-success-inner {
    max-width: 580px;
    margin: 0 auto;
  }
  .demo-success-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 40px 36px;
    text-align: center;
    box-shadow: var(--shadow);
  }
  .demo-success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--accent2), #059669);
    color: white;
    border-radius: 50%;
    font-size: 1.6rem;
    font-weight: 700;
    margin-bottom: 16px;
  }
  .demo-success-card h2 {
    font-size: 1.35rem;
    margin-bottom: 12px;
    color: var(--text);
  }
  .demo-success-card p {
    color: var(--text-2);
    line-height: 1.65;
    margin-bottom: 20px;
  }
  .demo-success-back {
    color: var(--brand);
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s;
    display: inline-block;
  }
  .demo-success-back:hover { transform: translateX(-4px); }
</style>
