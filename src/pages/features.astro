---
import BaseLayout from '~/components/layout/BaseLayout.astro';
import FeatureGroup from '~/components/sections/FeatureGroup.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';

const moneyFeatures = [
  {
    title: 'Sales, Credit & Collections',
    body: "Record every sale in seconds — cash or credit. Track customer balances, supplier debts, and payments in one ledger. Auto-updates stock and keeps a full contact book of who owes what.",
    example: '"Sold 2 cartons of soap at 4,500 to Kwame, he\'ll pay Friday"',
    iconPath: 'M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  {
    title: 'Expense Logging',
    body: "Log every business expense — transport, rent, fuel, restocking. Know exactly where your money is going.",
    example: '"Spent 8,000 on transport and fuel today"',
    iconPath: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M16 13H8M16 17H8',
  },
  {
    title: 'Daily & Weekly Reports',
    body: 'Automatic summary every evening at 8pm and every Monday morning showing sales, profit, and top products.',
    example: 'Auto-sent every day at 8pm your local time',
    iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
  },
  {
    title: 'Cash Flow Forecast',
    body: '4 weeks of actual cash flow plus 4 weeks projected at your current pace. Know your month-end balance before it happens.',
    example: 'Plan ahead with confidence, not guesswork',
    iconPath: 'M2 3h20v14H2zM8 21h8M12 17v4',
  },
  {
    title: 'Sales Comparison',
    body: 'This month vs last month — revenue, transactions, and average order value side by side with percentage changes.',
    example: 'This month vs last — instantly',
    iconPath: 'M18 20V10M12 20V4M6 20v-6',
  },
  {
    title: 'Revenue by Category',
    body: 'See which product categories drive the most revenue with visual breakdowns to decide what to stock more of.',
    example: 'Know exactly where your money comes from',
    iconPath: 'M21.21 15.89A10 10 0 118 2.83M22 12A10 10 0 0012 2v10z',
  },
  {
    title: 'Weekly Sales Velocity',
    body: 'Weekly revenue trends with growth percentages, best/worst week highlights, and a 4-week moving average to spot seasonality.',
    example: 'Spot trends before they become problems',
    iconPath: 'M23 6l-9.5 9.5-5-5L1 18M17 6h6v6',
  },
  {
    title: 'PDF Report Downloads',
    body: 'Request sales, expenses, or P&L reports via WhatsApp and get a direct PDF download link. PIN-secured for privacy.',
    example: '"Export my sales" → PDF link with 4-digit PIN',
    iconPath: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M12 18v-6M9 15l3 3 3-3',
  },
];

const inventoryFeatures = [
  {
    title: 'Inventory Management',
    body: 'Track stock in and out automatically. Get alerts when items run low so you never run out of your best sellers.',
    example: '"Added 50 bags of sugar from a local supplier"',
    iconPath: 'M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0',
  },
  {
    title: 'Smart Search',
    body: 'Instant search across inventory, sales, and expenses. Type a product name, customer, or category and results filter in real time.',
    example: 'Find anything across your business in milliseconds',
    iconPath: 'M11 19a8 8 0 100-16 8 8 0 000 16zM21 21l-4.35-4.35',
  },
  {
    title: 'Inventory Restock',
    body: 'One-click restock button on every product card. Enter quantity and optional cost — stock updates instantly.',
    example: 'Restock in 2 taps from the dashboard',
    iconPath: 'M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12',
  },
  {
    title: 'Smart CSV Import Modes',
    body: 'Import with context: New Purchase, Existing Stock (migration), Price Update Only, Historical Sales, or Existing Debts. Thousands of records in seconds.',
    example: 'One mode per scenario — no confusion',
    iconPath: 'M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3',
  },
  {
    title: 'Order Reservations',
    body: 'Track all stock holds from dashboard, WhatsApp, and Voice AI in one place. Source badges, hold countdowns, and one-click sell/release/cancel actions.',
    example: '"Hold 5 bags of rice for Kwame until Friday"',
    iconPath: 'M3 4h18v18H3zM16 2v4M8 2v4M3 10h18',
  },
];

const teamFeatures = [
  {
    title: 'Multi-Staff Support',
    body: "Add your shop attendants as staff. They record sales while you track everything from your own WhatsApp.",
    example: 'Owner + Staff roles with separate access',
    iconPath: 'M22 11.08V12a10 10 0 11-5.93-9.14M22 4L12 14.01l-3-3',
  },
  {
    title: 'Role-Based Access',
    body: 'Owners see everything. Staff only see what you allow. Audit trail per user so you know who recorded what.',
    example: 'Permissions tuned per role',
    iconPath: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 11l-3 3-2-2',
  },
  {
    title: 'Web Dashboard',
    body: 'Visualize your business with charts, trend graphs, and filterable reports. Works on mobile and desktop browser.',
    example: 'View sales trends, top products, profit margins',
    iconPath: 'M3 3h18v18H3zM3 9h18M9 21V3',
  },
];
---

<BaseLayout
  title="Features — Ojunai"
  description="The full Ojunai feature set: sales, credit and collections, inventory, reports, multi-staff, CSV import, dashboard, Voice AI add-on. Built for African SMEs."
  canonical="/features"
  ogImage="/og/features.png"
>
  <section class="features-hero">
    <div class="container">
      <div class="features-hero-inner">
        <div class="features-hero-pill">All Features</div>
        <h1>Everything Ojunai does, in one place.</h1>
        <p>
          Sixteen features across sales, inventory, reporting, team, and Voice AI — all driven by
          a single chat on WhatsApp. No app downloads. No spreadsheets.
        </p>
      </div>
    </div>
  </section>

  <FeatureGroup
    label="Sales &amp; Money"
    title="From the first sale to the last payment"
    intro="Every transaction recorded, every customer balance tracked, every report generated automatically."
    features={moneyFeatures}
    screenshot={{
      src: '/screenshots/sales.png',
      alt: 'Ojunai sales page showing transactions from WhatsApp, manual entry, and CSV import',
    }}
    learnMoreHref="/features/sales-management"
    learnMoreLabel="Deep-dive on sales & credit →"
  />

  <FeatureGroup
    label="Inventory &amp; Stock"
    title="Stock that tracks itself"
    intro="Auto-updating quantities, low-stock alerts, fast search, bulk import, and reservations — all driven from chat."
    features={inventoryFeatures}
    screenshot={{
      src: '/screenshots/inventory-page.png',
      alt: 'Ojunai inventory page showing product stock levels and categories',
    }}
    learnMoreHref="/features/inventory-management"
    learnMoreLabel="Deep-dive on inventory →"
  />

  <FeatureGroup
    label="Team &amp; Access"
    title="One owner, many hands"
    intro="Bring shop attendants on board with their own WhatsApp access. You see everything they record on your dashboard, in real time."
    features={teamFeatures}
  />

  <section class="voice-feature-tease">
    <div class="container">
      <div class="voice-feature-card">
        <div class="voice-feature-meta">
          <span class="voice-feature-pill">🎤 Premium Add-on</span>
          <h2>Voice AI — your 24/7 phone receptionist</h2>
          <p>
            Answer customer calls in English, Yoruba, Hausa or Igbo. Confirm stock and pricing.
            Reserve items on the dashboard for pickup. Available with any plan from ₦5,000/month.
          </p>
          <a href="/voice-ai" class="voice-feature-cta">Learn how Voice AI works →</a>
        </div>
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>

<style>
  .features-hero {
    background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg) 100%);
    padding: 160px 0 60px;
    text-align: center;
  }
  .features-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }
  .features-hero-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .features-hero h1 {
    font-size: clamp(2rem, 4.4vw, 3rem);
    line-height: 1.15;
    color: var(--text);
    margin-bottom: 16px;
  }
  .features-hero p {
    font-size: 1.1rem;
    color: var(--text-2);
    line-height: 1.65;
  }

  .voice-feature-tease {
    padding: 60px 0;
  }
  .voice-feature-card {
    border-radius: 24px;
    overflow: hidden;
    background: radial-gradient(120% 140% at 0% 0%, #1E1B4B 0%, #0B0B22 60%, #050516 100%);
    color: white;
    padding: 56px 48px;
    border: 1px solid rgba(99, 102, 241, 0.2);
    box-shadow: 0 30px 80px rgba(67, 56, 202, 0.25);
  }
  .voice-feature-meta { max-width: 720px; }
  .voice-feature-pill {
    display: inline-block;
    background: rgba(99, 102, 241, 0.2);
    color: #C7D2FE;
    border: 1px solid rgba(165, 180, 252, 0.35);
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .voice-feature-meta h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    line-height: 1.2;
    margin-bottom: 14px;
    color: white;
  }
  .voice-feature-meta p {
    color: #CBD5E1;
    font-size: 1.05rem;
    line-height: 1.65;
    margin-bottom: 18px;
  }
  .voice-feature-cta {
    color: #A5B4FC;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, color 0.2s;
    display: inline-block;
  }
  .voice-feature-cta:hover { transform: translateX(4px); color: white; }
</style>
