---
import BaseLayout from '~/components/layout/BaseLayout.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';

const pillars = [
  {
    title: 'Encryption in transit & at rest',
    body: 'Every connection between you, the WhatsApp bot, and our dashboard uses TLS 1.2+. Sensitive fields are encrypted at rest in the database with AES-256. Backups are encrypted with separate keys.',
    iconPath: 'M3 11h18v11H3zM7 11V7a5 5 0 0110 0v4',
  },
  {
    title: 'Role-based access',
    body: 'Owners see everything. Staff only see what you allow. Per-user audit logs record who recorded which sale, expense, or stock change — so disputes resolve in minutes, not days.',
    iconPath: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 11l-3 3-2-2',
  },
  {
    title: 'Daily automated backups',
    body: 'Full database snapshots every 24 hours, retained for 30 days. Point-in-time recovery within the last 7 days. Backups live in a different region from the primary database.',
    iconPath: 'M21 12a9 9 0 11-6.219-8.56M21 4v6h-6',
  },
  {
    title: 'Hardened infrastructure',
    body: 'Servers run on Hetzner with SSH key-only access, firewall rules locked to known sources, automatic OS security patches, and intrusion detection. No SSH password logins, ever.',
    iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  {
    title: 'You own your data',
    body: 'Export sales, expenses, inventory, contacts, and reservations as CSV any time from the dashboard. Cancel and delete and we permanently wipe your records within 30 days.',
    iconPath: 'M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3',
  },
  {
    title: 'No third-party tracking',
    body: 'No advertising pixels, no cross-site trackers, no behavioral profiling. The only data we process is what you explicitly send us. We never sell or share business records with anyone.',
    iconPath: 'M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zM12 14c-4.42 0-8 3.58-8 8h16c0-4.42-3.58-8-8-8z',
  },
];

const compliance = [
  {
    label: 'NDPR aligned',
    body: 'Built to align with the Nigeria Data Protection Regulation. Data Protection Officer designated. Data Subject Access Requests honored within 30 days.',
  },
  {
    label: 'GDPR principles',
    body: 'European data subjects have the same rights — access, correction, deletion, portability, objection — even though our primary jurisdiction is Nigeria.',
  },
  {
    label: 'PCI-DSS via partners',
    body: 'We never store card numbers ourselves. All card payments are processed by Paystack and Flutterwave, which are PCI-DSS Level 1 compliant.',
  },
  {
    label: 'Working toward SOC 2',
    body: 'Internal controls documented; external audit planned within the next 12 months. Track our progress at trust.ojunai.com once published.',
  },
];

const faqs = [
  {
    q: 'Where is my data physically stored?',
    a: 'Production database and primary application servers run in Hetzner data centers in Germany (Falkenstein region). Backups are replicated to a secondary region. We chose European hosting for the strong default privacy posture, even though most of our customers are in Africa.',
  },
  {
    q: 'How do I report a security issue?',
    a: 'Email security@ojunai.com with details. We aim to acknowledge within 24 hours and triage within 72. Coordinated disclosure is welcomed; we do not pursue legal action against good-faith researchers.',
  },
  {
    q: 'What happens during an outage?',
    a: 'Our target is 99.5% monthly uptime. Real-time status will be at status.ojunai.com once published; for now, we send WhatsApp updates to affected customers within 30 minutes of detection. Post-incident reviews are shared by email when impact warrants it.',
  },
  {
    q: 'Can I get a Data Processing Agreement (DPA)?',
    a: 'Yes — for Business plan customers and for any customer in a regulated industry. Email contact@ojunai.com and we will send our standard DPA template.',
  },
];
---

<BaseLayout
  title="Security & Trust — Ojunai"
  description="How Ojunai protects your business data: bank-grade encryption, role-based access, daily backups, NDPR/GDPR posture, and incident response. Your data stays yours."
  canonical="/security"
  ogImage="/og/security.png"
>
  <section class="security-hero">
    <div class="container security-hero-inner">
      <span class="security-hero-pill">Security &amp; Trust</span>
      <h1>Your data, locked down.</h1>
      <p>
        Encryption in transit and at rest. Daily backups. Role-based access. NDPR and GDPR
        principles followed. You own your records — always.
      </p>
    </div>
  </section>

  <section class="section security-pillars">
    <div class="container">
      <div class="security-grid">
        {pillars.map((p) => (
          <div class="security-card">
            <div class="security-icon">
              <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path d={p.iconPath} />
              </svg>
            </div>
            <h3>{p.title}</h3>
            <p>{p.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section security-compliance">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Compliance</div>
        <h2>How we map to the standards that matter</h2>
        <p>We don't claim certifications we haven't earned. Here's exactly where we are.</p>
      </div>
      <div class="compliance-grid">
        {compliance.map((c) => (
          <div class="compliance-row">
            <strong>{c.label}</strong>
            <p>{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section security-faq">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Frequently Asked</div>
        <h2>Security questions</h2>
      </div>
      <div class="security-faq-list">
        {faqs.map((f) => (
          <details class="security-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
      <p class="security-contact">
        For security disclosures or DPA requests: <a href="mailto:security@ojunai.com">security@ojunai.com</a>
      </p>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>

<style>
  .security-hero {
    padding: 160px 0 60px;
    background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg) 100%);
    text-align: center;
  }
  .security-hero-inner { max-width: 720px; margin: 0 auto; }
  .security-hero-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .security-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.4rem);
    line-height: 1.1;
    margin-bottom: 16px;
    color: var(--text);
  }
  .security-hero p {
    font-size: 1.1rem;
    color: var(--text-2);
    line-height: 1.6;
  }

  .security-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 960px) { .security-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .security-grid { grid-template-columns: 1fr; } }

  .security-card {
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .security-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--brand-mid);
  }
  .security-icon {
    width: 44px; height: 44px;
    background: linear-gradient(135deg, var(--brand), var(--brand-mid));
    color: white;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .security-card h3 {
    font-size: 1.1rem;
    color: var(--text);
    margin-bottom: 8px;
  }
  .security-card p {
    color: var(--text-2);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .security-compliance { background: var(--bg-alt); }
  .compliance-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
  }
  @media (max-width: 768px) { .compliance-grid { grid-template-columns: 1fr; } }
  .compliance-row {
    background: white;
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 24px 26px;
  }
  .compliance-row strong {
    display: block;
    color: var(--brand);
    font-size: 0.95rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .compliance-row p {
    color: var(--text-2);
    font-size: 0.95rem;
    line-height: 1.55;
  }

  .security-faq-list { max-width: 780px; margin: 0 auto; }
  .security-faq-item {
    background: white;
    border: 1px solid var(--border);
    border-radius: 12px;
    margin-bottom: 12px;
  }
  .security-faq-item[open] { border-color: var(--brand-mid); }
  .security-faq-item summary {
    padding: 18px 24px;
    cursor: pointer;
    font-weight: 600;
    color: var(--text);
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .security-faq-item summary::-webkit-details-marker { display: none; }
  .security-faq-item summary::after {
    content: '+';
    font-size: 1.4rem;
    color: var(--brand);
    transition: transform 0.2s;
  }
  .security-faq-item[open] summary::after { transform: rotate(45deg); }
  .security-faq-item p {
    padding: 0 24px 20px;
    color: var(--text-2);
    line-height: 1.65;
  }
  .security-contact {
    text-align: center;
    margin-top: 32px;
    color: var(--text-2);
  }
  .security-contact a { color: var(--brand); text-decoration: underline; }
</style>
