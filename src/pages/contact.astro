---
import BaseLayout from '~/components/layout/BaseLayout.astro';
---

<BaseLayout
  title="Contact — Ojunai"
  description="Reach Ojunai sales, support or our security team. Email and WhatsApp paths with response-time SLAs. Built for African business owners."
  canonical="/contact"
>
  <section class="contact-hero">
    <div class="container contact-hero-inner">
      <span class="contact-hero-pill">Talk to us</span>
      <h1>We pick up the phone (literally).</h1>
      <p>Pick the path that matches what you need. We respond fast.</p>
    </div>
  </section>

  <section class="section contact-paths">
    <div class="container">
      <div class="contact-grid">
        <a class="contact-card" href="mailto:contact@ojunai.com?subject=Sales%20inquiry">
          <div class="contact-icon contact-icon-sales">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3" />
            </svg>
          </div>
          <h3>Sales</h3>
          <p>Business plan, multi-branch setup, integrations, custom needs, partnerships.</p>
          <strong>contact@ojunai.com</strong>
          <span class="contact-sla">Response within 1 business day</span>
        </a>

        <a class="contact-card" href="mailto:support@ojunai.com?subject=Support%20question">
          <div class="contact-icon contact-icon-support">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <circle cx="12" cy="12" r="10" />
              <path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3M12 17h.01" />
            </svg>
          </div>
          <h3>Support</h3>
          <p>Existing customers — billing, login, feature questions, bug reports.</p>
          <strong>support@ojunai.com</strong>
          <span class="contact-sla">Response within 4 hours · 9am–9pm WAT, weekdays</span>
        </a>

        <a
          class="contact-card"
          href="https://wa.me/16137128154"
          target="_blank"
          rel="noopener"
        >
          <div class="contact-icon contact-icon-whatsapp">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
            </svg>
          </div>
          <h3>WhatsApp</h3>
          <p>Quick questions, demos, anything you'd rather just say than type out.</p>
          <strong>+1 613 712 8154</strong>
          <span class="contact-sla">Read receipts on, replies same-day</span>
        </a>

        <a class="contact-card" href="mailto:security@ojunai.com?subject=Security%20disclosure">
          <div class="contact-icon contact-icon-security">
            <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
          </div>
          <h3>Security</h3>
          <p>Disclosures, DPA requests, audit questions. Coordinated disclosure welcomed.</p>
          <strong>security@ojunai.com</strong>
          <span class="contact-sla">Acknowledged within 24h · triaged within 72h</span>
        </a>
      </div>
    </div>
  </section>

  <section class="contact-cta">
    <div class="container contact-cta-inner">
      <h2>Prefer to start with the product?</h2>
      <p>Skip the email and try Ojunai free for 30 days. Sign up on WhatsApp in under 60 seconds.</p>
      <a
        href="https://wa.me/14155238886?text=join%20knife-wait"
        target="_blank"
        rel="noopener"
        class="btn-primary btn-large"
      >
        Start free on WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-hero {
    padding: 160px 0 60px;
    background: linear-gradient(180deg, var(--bg-alt) 0%, var(--bg) 100%);
    text-align: center;
  }
  .contact-hero-inner { max-width: 720px; margin: 0 auto; }
  .contact-hero-pill {
    display: inline-block;
    background: var(--brand-light);
    color: var(--brand);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 100px;
    margin-bottom: 20px;
  }
  .contact-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.2rem);
    line-height: 1.1;
    margin-bottom: 14px;
  }
  .contact-hero p {
    font-size: 1.1rem;
    color: var(--text-2);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 768px) { .contact-grid { grid-template-columns: 1fr; } }

  .contact-card {
    display: block;
    background: white;
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px 28px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .contact-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: var(--brand-mid);
  }
  .contact-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    color: white;
    margin-bottom: 16px;
  }
  .contact-icon-sales    { background: linear-gradient(135deg, #4F46E5, #6366F1); }
  .contact-icon-support  { background: linear-gradient(135deg, #06B6D4, #0EA5E9); }
  .contact-icon-whatsapp { background: linear-gradient(135deg, #25D366, #128C7E); }
  .contact-icon-security { background: linear-gradient(135deg, #EF4444, #B91C1C); }

  .contact-card h3 {
    font-size: 1.2rem;
    color: var(--text);
    margin-bottom: 8px;
  }
  .contact-card p {
    color: var(--text-2);
    font-size: 0.95rem;
    line-height: 1.55;
    margin-bottom: 16px;
  }
  .contact-card strong {
    display: block;
    color: var(--brand);
    font-family: var(--font-display);
    font-size: 1.05rem;
    margin-bottom: 6px;
  }
  .contact-sla {
    font-size: 0.82rem;
    color: var(--text-3);
  }

  .contact-cta {
    background: linear-gradient(135deg, var(--brand-dark), var(--brand));
    color: white;
    padding: 80px 0;
  }
  .contact-cta-inner {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }
  .contact-cta h2 {
    color: white;
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    margin-bottom: 12px;
  }
  .contact-cta p {
    color: #C7D2FE;
    margin-bottom: 28px;
  }
</style>
