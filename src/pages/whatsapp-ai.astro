---
import BaseLayout from '~/components/layout/BaseLayout.astro';
import HeroPhone from '~/components/sections/HeroPhone.astro';
import FinalCTA from '~/components/sections/FinalCTA.astro';

const capabilities = [
  {
    title: 'Plain English & Pidgin',
    body: "Chat naturally — \"Sold 5 bags of rice at 3,000 each\" or \"Don sell 5 bag of rice for 3000 each.\" Ojunai parses both with the same accuracy.",
    iconPath: 'M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z',
  },
  {
    title: 'Sales recording from anywhere',
    body: 'Log a sale from your back office, the front of the shop, your delivery van, or the supplier yard. Anywhere your phone has WhatsApp.',
    iconPath: 'M12 1v22M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6',
  },
  {
    title: 'Inventory updates by chat',
    body: 'Tell the bot what came in, what was returned, what was damaged. Stock levels update on your dashboard in real time, no manual reconciliation.',
    iconPath: 'M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0',
  },
  {
    title: 'Debt & credit tracking',
    body: '"Kwame paid 20,000 off his debt." "Show me everyone owing me." Customer balances and aging update on your dashboard automatically.',
    iconPath: 'M22 12h-4l-3 9L9 3l-3 9H2',
  },
  {
    title: 'Daily & weekly reports',
    body: 'Auto-summary at 8pm every evening with sales, expenses, profit, top products. Weekly review every Monday morning. No login required.',
    iconPath: 'M3 3h18v18H3zM3 9h18M9 21V3',
  },
  {
    title: 'PDF report exports',
    body: 'Send "export my sales" and get a PIN-secured PDF download link delivered to the same chat. Works for sales, expenses, debts, and full P&L.',
    iconPath: 'M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8zM14 2v6h6M12 18v-6M9 15l3 3 3-3',
  },
  {
    title: 'Multi-staff with roles',
    body: 'Add shop attendants as staff. They record sales from their own WhatsApp; you see everything consolidated on your dashboard with audit trail.',
    iconPath: 'M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 11l-3 3-2-2',
  },
  {
    title: 'Smart confirmations',
    body: "Bot asks for clarification when unsure. Nothing is recorded until it's confident. You stay in control — every transaction is your call.",
    iconPath: 'M22 11.08V12a10 10 0 11-5.93-9.14M22 4L12 14.01l-3-3',
  },
  {
    title: 'Owner override anytime',
    body: 'Edit, undo, or recategorize any transaction from the dashboard. WhatsApp is the input — the dashboard is your full control panel.',
    iconPath: 'M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z',
  },
];

const setup = [
  {
    n: '01',
    title: 'Pick a plan with WhatsApp AI',
    body: 'WhatsApp AI is included on Shop, Pro, and Business plans (Starter is dashboard-only). One-month free trial covers it.',
  },
  {
    n: '02',
    title: 'Connect your WhatsApp number',
    body: 'During signup or from the dashboard. We send a verification message; you reply with the code. Takes ~60 seconds.',
  },
  {
    n: '03',
    title: 'Start chatting',
    body: '"Sold 3 bags of rice at 4,500 each" — and you\'re live. The bot confirms, records, and your dashboard updates in real time.',
  },
];

const faqs = [
  {
    q: "Will it understand my Pidgin?",
    a: "Yes. Ojunai's language model is trained on West and East African phrasing — Lagos, Accra, Nairobi accents and code-switching between English and Pidgin in the same message. Accuracy is materially higher than generic English-only models for African business owners.",
  },
  {
    q: "What if it misunderstands a message?",
    a: "Ojunai asks for clarification before recording when it's not confident. If a transaction does get recorded incorrectly, you can edit or undo it from the dashboard — every change has an audit trail.",
  },
  {
    q: "Can my staff use it from their own phones?",
    a: "Yes. Add staff accounts from the dashboard with the role you want (Recorder, Manager, Owner). They sign in with their own WhatsApp number; you see all their entries consolidated on your dashboard with per-user attribution.",
  },
  {
    q: "Do messages count against a monthly limit?",
    a: "Yes — Shop plan is 850 messages/month, Pro and Business are unlimited. Most one-shop owners use 200–500 messages/month. We'll alert you well before the limit if you're trending high.",
  },
  {
    q: "Is my chat history private?",
    a: "Yes. Messages are encrypted in transit (WhatsApp's E2E) and at rest in our database. We process your message content through Claude (Anthropic) for natural-language understanding only — never used for advertising, never sold, never shared. Full details on the security page.",
  },
  {
    q: "What happens if WhatsApp goes down?",
    a: "Your data is safe — it lives in your dashboard, not in WhatsApp. During WhatsApp outages, you can record sales directly via the web dashboard at app.ojunai.com. Recent transactions sync back when service resumes.",
  },
  {
    q: "Can I attach photos of receipts or products?",
    a: "Image attachments are on the roadmap for Q3 2026. For now, the bot processes text-based commands. You can upload product photos via the web dashboard.",
  },
];

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Ojunai WhatsApp AI',
  description:
    'AI-powered WhatsApp business assistant that records sales, manages inventory, tracks debts, and delivers daily reports. Speaks plain English and Pidgin. Built for African SMEs.',
  brand: { '@type': 'Brand', name: 'Ojunai' },
  offers: {
    '@type': 'Offer',
    description: 'Included on Shop, Pro and Business plans. From ₦7,500/month.',
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout
  title="WhatsApp AI — Ojunai"
  description="Run your inventory, sales, debts and reports entirely through WhatsApp. Plain English and Pidgin understood. Daily summaries, PDF exports, multi-staff support — all from a chat. Available on Shop, Pro, and Business plans."
  canonical="/whatsapp-ai"
  ogImage="/og/whatsapp-ai.png"
  jsonLd={[productSchema, faqSchema]}
>
  <!-- HERO -->
  <section class="wa-hero">
    <div class="wa-hero-glow-green"></div>
    <div class="wa-hero-glow-purple"></div>
    <div class="container wa-hero-grid">
      <div class="wa-hero-content">
        <span class="wa-hero-pill">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
          </svg>
          WhatsApp AI Add-on
        </span>
        <h1>Your business, <span class="wa-hero-grad">in your pocket</span>.</h1>
        <p class="wa-hero-sub">
          Record every sale, every restock, every debt — all by chatting with our AI on WhatsApp.
          Plain English or Pidgin. Daily summaries auto-delivered. Multi-staff. PDF exports on demand.
        </p>
        <div class="wa-hero-ctas">
          <a
            href="https://app.ojunai.com/register"
            target="_blank"
            rel="noopener"
            class="btn-cta-primary"
          >
            Start free
          </a>
          <a href="#pricing" class="wa-hero-link">See pricing →</a>
        </div>
        <p class="wa-hero-meta">
          From <strong>₦7,500/month</strong> · Included on Shop, Pro &amp; Business plans
        </p>
      </div>

      <div class="wa-hero-phone">
        <HeroPhone status="typing…">
          <div class="chat-bubble outgoing">
            <p>Sold 5 bags of rice at 3,000 each to Kwame, he'll pay Friday</p>
            <span class="chat-time">2:14 PM</span>
          </div>
          <div class="chat-bubble incoming">
            <p>✅ Recorded.</p>
            <p>5× Rice (50kg) @ ₦3,000 = <strong>₦15,000</strong></p>
            <p>👤 Kwame · Due Friday<br>📦 Stock: 12 bags left</p>
            <span class="chat-time">2:14 PM</span>
          </div>
          <div class="chat-bubble outgoing">
            <p>Received 50 bags of sugar from Dangote, total 180k</p>
            <span class="chat-time">2:42 PM</span>
          </div>
          <div class="chat-bubble incoming">
            <p>📦 +50 bags Sugar (50kg) added.</p>
            <p>💰 Expense: ₦180,000 to Dangote</p>
            <p>Stock now: 78 bags</p>
            <span class="chat-time">2:42 PM</span>
          </div>
        </HeroPhone>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="wa-stats">
    <div class="container wa-stats-grid">
      <div class="wa-stat">
        <div class="wa-stat-num">&lt;10s</div>
        <p>To log a sale, vs 2-3 minutes in a notebook.</p>
      </div>
      <div class="wa-stat">
        <div class="wa-stat-num">2</div>
        <p>Languages understood out of the box: English &amp; Pidgin.</p>
      </div>
      <div class="wa-stat">
        <div class="wa-stat-num">8pm</div>
        <p>Daily summary auto-delivered, every evening.</p>
      </div>
      <div class="wa-stat">
        <div class="wa-stat-num">0</div>
        <p>Apps to download. WhatsApp is already on every phone.</p>
      </div>
    </div>
  </section>

  <!-- CAPABILITIES -->
  <section class="wa-capabilities">
    <div class="container">
      <div class="section-header">
        <div class="section-label">What it handles</div>
        <h2>Everything your books need, by chat.</h2>
        <p>Nine ways WhatsApp AI keeps your dashboard current — without you ever opening a browser.</p>
      </div>
      <div class="wa-capability-grid">
        {capabilities.map((c) => (
          <div class="wa-capability-card">
            <div class="wa-capability-icon">
              <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
                <path d={c.iconPath} />
              </svg>
            </div>
            <h3>{c.title}</h3>
            <p>{c.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- LIVE EXAMPLES — 4 themed chat scenarios -->
  <section class="wa-examples">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Real conversations</div>
        <h2>What it actually looks like.</h2>
        <p>Four scenarios from real Ojunai shops. Every reply is generated live — these are not staged.</p>
      </div>

      <div class="wa-example-grid">
        <!-- Sales -->
        <div class="wa-example-card">
          <div class="wa-example-header">
            <span class="wa-example-tag">Sales</span>
            <h3>Recording a sale on credit</h3>
          </div>
          <HeroPhone status="online">
            <div class="chat-bubble outgoing">
              <p>Ama bought 2 cartons of soap at 4,500, said she'll pay end of week</p>
              <span class="chat-time">10:22 AM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>Got it.</p>
              <p>2× Soap (carton) @ ₦4,500 = <strong>₦9,000</strong></p>
              <p>👤 Ama (credit · due Sunday)<br>📦 Soap: 18 cartons left<br>💸 Ama's balance: ₦9,000</p>
              <span class="chat-time">10:22 AM</span>
            </div>
          </HeroPhone>
        </div>

        <!-- Inventory -->
        <div class="wa-example-card">
          <div class="wa-example-header">
            <span class="wa-example-tag wa-example-tag-blue">Inventory</span>
            <h3>Restock from a supplier</h3>
          </div>
          <HeroPhone status="online">
            <div class="chat-bubble outgoing">
              <p>Got 100 packs of Indomie from market today, paid 95k cash</p>
              <span class="chat-time">8:45 AM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>Logged.</p>
              <p>📦 +100 Indomie packs (cost ₦950 each)</p>
              <p>💸 Expense: ₦95,000 (cash)</p>
              <p>Stock now: 142 packs</p>
              <span class="chat-time">8:45 AM</span>
            </div>
          </HeroPhone>
        </div>

        <!-- Debt -->
        <div class="wa-example-card">
          <div class="wa-example-header">
            <span class="wa-example-tag wa-example-tag-orange">Debt</span>
            <h3>Recording a partial payment</h3>
          </div>
          <HeroPhone status="online">
            <div class="chat-bubble outgoing">
              <p>Show me everyone owing me</p>
              <span class="chat-time">5:30 PM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>👥 <strong>3 customers owing ₦67,000</strong></p>
              <p>• Kwame — ₦15,000 (due tomorrow)<br>• Ama — ₦9,000 (due Sun)<br>• Chidi — ₦43,000 (overdue 4d)</p>
              <span class="chat-time">5:30 PM</span>
            </div>
            <div class="chat-bubble outgoing">
              <p>Chidi just paid 20,000</p>
              <span class="chat-time">5:31 PM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>✅ ₦20,000 applied to Chidi.</p>
              <p>New balance: ₦23,000 (still overdue 4d)</p>
              <span class="chat-time">5:31 PM</span>
            </div>
          </HeroPhone>
        </div>

        <!-- Reports -->
        <div class="wa-example-card">
          <div class="wa-example-header">
            <span class="wa-example-tag wa-example-tag-purple">Reports</span>
            <h3>Pulling a PDF on demand</h3>
          </div>
          <HeroPhone status="online">
            <div class="chat-bubble outgoing">
              <p>Export my sales for this month</p>
              <span class="chat-time">9:12 AM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>📄 Generating sales report (Apr 1–30, 2026)…</p>
              <span class="chat-time">9:12 AM</span>
            </div>
            <div class="chat-bubble incoming">
              <p>✅ Ready.</p>
              <p><strong>Download (PIN-secured):</strong><br>ojunai.com/r/8f3kq2x</p>
              <p>🔐 PIN: <strong>4729</strong> (link expires in 24h)</p>
              <span class="chat-time">9:12 AM</span>
            </div>
          </HeroPhone>
        </div>
      </div>
    </div>
  </section>

  <!-- DAILY & WEEKLY REPORTS -->
  <section class="wa-reports">
    <div class="container wa-reports-grid">
      <div class="wa-reports-meta">
        <div class="section-label">Auto-delivered</div>
        <h2>Daily &amp; weekly reports — sent to you, not requested.</h2>
        <p>
          Every evening at 8pm (your local time), Ojunai sends a full summary of your business day.
          Every Monday morning, a weekly review with growth trends and top movers. No login required.
        </p>
        <ul class="wa-reports-list">
          <li>
            <strong>Daily 8pm summary</strong> — revenue, expenses, net profit, top product, low-stock alerts, customers owing.
          </li>
          <li>
            <strong>Monday weekly review</strong> — week-over-week comparison, sales velocity, best/worst day, customer acquisition.
          </li>
          <li>
            <strong>Custom on demand</strong> — "show me last 7 days," "what's my profit this month," anytime.
          </li>
        </ul>
      </div>

      <div class="wa-reports-phone">
        <HeroPhone status="online">
          <div class="chat-bubble incoming">
            <p>📊 <strong>Evening Summary — Mon Apr 7</strong></p>
            <p>💰 Revenue: <strong>₦287,500</strong><br>📉 Expenses: <strong>₦42,000</strong><br>📈 Net Profit: <strong>₦245,500</strong></p>
            <p>🏆 Top Product: <em>Rice Bag (12 sold)</em><br>⚠️ Low Stock: <em>Tomato Tin (4 left)</em><br>👥 Owing: <em>3 (₦67,000)</em></p>
            <p>Great day! Keep it up 💪</p>
            <span class="chat-time">8:00 PM</span>
          </div>
        </HeroPhone>
      </div>
    </div>
  </section>

  <!-- STAFF SECTION -->
  <section class="wa-staff">
    <div class="container wa-staff-grid">
      <div class="wa-staff-phone">
        <HeroPhone status="online">
          <div class="chat-bubble incoming">
            <p>👥 <strong>Staff Activity Today</strong></p>
            <p>• <strong>Tunde</strong> (Front desk): 14 sales, ₦98,200<br>• <strong>Ada</strong> (Counter 2): 19 sales, ₦134,500<br>• <strong>You</strong>: 6 sales, ₦54,800</p>
            <p>Total: 39 sales, ₦287,500</p>
            <span class="chat-time">7:55 PM</span>
          </div>
        </HeroPhone>
      </div>

      <div class="wa-staff-meta">
        <div class="section-label">Multi-staff</div>
        <h2>Many hands, one ledger.</h2>
        <p>
          Add your shop attendants as staff on the dashboard. They record sales from their own
          WhatsApp; you see everything consolidated with per-staff attribution. Three roles —
          Recorder, Manager, Owner — let you control what each person can see and do.
        </p>
        <ul class="wa-staff-list">
          <li><strong>Per-user audit trail</strong> — every entry tagged with who recorded it.</li>
          <li><strong>Role-based access</strong> — Recorders log; Managers see reports; Owners see everything.</li>
          <li><strong>Real-time consolidation</strong> — your dashboard updates as each staff member records.</li>
          <li><strong>Available on Shop, Pro &amp; Business</strong> — up to 3, 10, and unlimited respectively.</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- PRICING CARD -->
  <section class="wa-pricing" id="pricing">
    <div class="container">
      <div class="wa-pricing-card">
        <div class="wa-pricing-meta">
          <span class="wa-pricing-pill">Included on Shop, Pro &amp; Business</span>
          <h2>Pricing</h2>
          <p>WhatsApp AI is included on every plan from Shop upward. Starter is dashboard-only — upgrade any time.</p>

          <div class="wa-pricing-tiers">
            <div class="wa-pricing-tier">
              <strong>Shop</strong>
              <div class="wa-pricing-tier-price">₦7,500<span>/mo</span></div>
              <p>Up to 3 staff · 850 messages/month</p>
            </div>
            <div class="wa-pricing-tier wa-pricing-tier-featured">
              <span class="wa-pricing-tier-badge">Most chosen</span>
              <strong>Pro</strong>
              <div class="wa-pricing-tier-price">₦12,500<span>/mo</span></div>
              <p>Up to 10 staff · Unlimited messages</p>
            </div>
            <div class="wa-pricing-tier">
              <strong>Business</strong>
              <div class="wa-pricing-tier-price">₦30,000<span>/mo</span></div>
              <p>Unlimited staff · API · Account manager</p>
            </div>
          </div>

          <div class="wa-pricing-actions">
            <a href="https://app.ojunai.com/register" target="_blank" rel="noopener" class="btn-cta-primary">
              Start free
            </a>
            <a href="/pricing" class="wa-pricing-link">Compare all plans →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SETUP -->
  <section class="wa-setup">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Setup</div>
        <h2>From signup to first sale, in 60 seconds.</h2>
      </div>
      <div class="wa-setup-steps">
        {setup.map((s) => (
          <div class="wa-setup-step">
            <div class="wa-setup-num">{s.n}</div>
            <h3>{s.title}</h3>
            <p>{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="wa-faq">
    <div class="container">
      <div class="section-header">
        <div class="section-label">Frequently Asked</div>
        <h2>WhatsApp AI questions</h2>
      </div>
      <div class="wa-faq-list">
        {faqs.map((f) => (
          <details class="wa-faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- RELATED -->
  <section class="wa-related">
    <div class="container wa-related-grid">
      <div class="wa-related-col">
        <h3>Other ways Ojunai works for you</h3>
        <ul>
          <li><a href="/voice"><span class="arrow">›</span> Voice AI — 24/7 phone receptionist</a></li>
          <li><a href="/features/inventory-management"><span class="arrow">›</span> Inventory management</a></li>
          <li><a href="/features/sales-management"><span class="arrow">›</span> Sales &amp; credit ledger</a></li>
        </ul>
      </div>
      <div class="wa-related-col">
        <h3>Learn more</h3>
        <ul>
          <li><a href="/features"><span class="arrow">›</span> All features</a></li>
          <li><a href="/security"><span class="arrow">›</span> Security &amp; trust</a></li>
          <li><a href="/customers"><span class="arrow">›</span> Customer stories</a></li>
          <li><a href="/help"><span class="arrow">›</span> Help center</a></li>
        </ul>
      </div>
    </div>
  </section>

  <FinalCTA />
</BaseLayout>

<style>
  /* ============ HERO ============ */
  .wa-hero {
    position: relative;
    overflow: hidden;
    padding: 160px 0 90px;
    background: radial-gradient(120% 140% at 30% 0%, #0F2D26 0%, #0B1F1A 50%, #050C0A 100%);
    color: white;
  }
  .wa-hero-glow-green {
    position: absolute;
    top: -150px;
    left: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(37, 211, 102, 0.30), transparent 60%);
    filter: blur(40px);
    pointer-events: none;
  }
  .wa-hero-glow-purple {
    position: absolute;
    bottom: -200px;
    right: -100px;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.25), transparent 60%);
    filter: blur(40px);
    pointer-events: none;
